---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/translations';
const lang = 'ar';
---

<BaseLayout title={t(lang, 'nav.about')} description={t(lang, 'about.subtitle')} lang={lang}>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <div class="text-center mb-16">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-6">
        {t(lang, 'about.title')} <span class="gradient-text">{t(lang, 'about.titleHighlight')}</span>
      </h1>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto leading-relaxed">{t(lang, 'about.subtitle')}</p>
    </div>

    <div class="space-y-8">
      <div class="glass-card p-8">
        <h2 class="text-2xl font-bold text-white mb-4 flex items-center gap-3">
          <span class="w-8 h-8 rounded-lg bg-neon-blue/10 flex items-center justify-center">
            <svg class="w-4 h-4 text-neon-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </span>
          {t(lang, 'about.vision')}
        </h2>
        <p class="text-gray-300 leading-relaxed text-lg">{t(lang, 'about.visionText')}</p>
      </div>

      <div class="glass-card p-8">
        <h2 class="text-2xl font-bold text-white mb-4 flex items-center gap-3">
          <span class="w-8 h-8 rounded-lg bg-neon-green/10 flex items-center justify-center">
            <svg class="w-4 h-4 text-neon-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </span>
          {t(lang, 'about.whatWeOffer')}
        </h2>
        <ul class="space-y-3 text-gray-300 text-lg">
          <li class="flex items-start gap-3"><span class="text-neon-blue mt-1">&#9670;</span><span><strong class="text-white">{t(lang, 'about.dailyNews')}</strong> — {t(lang, 'about.dailyNewsDesc')}</span></li>
          <li class="flex items-start gap-3"><span class="text-neon-green mt-1">&#9670;</span><span><strong class="text-white">{t(lang, 'about.deepAnalysis')}</strong> — {t(lang, 'about.deepAnalysisDesc')}</span></li>
          <li class="flex items-start gap-3"><span class="text-purple-400 mt-1">&#9670;</span><span><strong class="text-white">{t(lang, 'about.toolReviews')}</strong> — {t(lang, 'about.toolReviewsDesc')}</span></li>
          <li class="flex items-start gap-3"><span class="text-pink-400 mt-1">&#9670;</span><span><strong class="text-white">{t(lang, 'about.futurePredictions')}</strong> — {t(lang, 'about.futurePredictionsDesc')}</span></li>
        </ul>
      </div>

      <div class="glass-card p-8">
        <h2 class="text-2xl font-bold text-white mb-4 flex items-center gap-3">
          <span class="w-8 h-8 rounded-lg bg-purple-500/10 flex items-center justify-center">
            <svg class="w-4 h-4 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </span>
          {t(lang, 'about.contact')}
        </h2>
        <p class="text-gray-300 leading-relaxed text-lg mb-4">{t(lang, 'about.contactText')}</p>
        <div class="flex flex-wrap gap-4">
          <a href="https://x.com/DayaHimour" target="_blank" rel="noopener noreferrer" class="btn-secondary text-sm">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" /></svg>
            {t(lang, 'footer.followX')}
          </a>
          <a href="https://github.com/dayahimour" target="_blank" rel="noopener noreferrer" class="btn-secondary text-sm">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" /></svg>
            GitHub
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
