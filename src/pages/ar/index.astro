---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import NewsCard from '../../components/NewsCard.astro';
import { t } from '../../i18n/translations';
import { getCollection } from 'astro:content';

const lang = 'ar';

const allPosts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// Featured: pick latest from different categories for variety
const usedCategories = new Set<string>();
const featuredPosts = allPosts.filter(p => {
  if (usedCategories.size >= 2) return false;
  if (usedCategories.has(p.data.category)) return false;
  usedCategories.add(p.data.category);
  return true;
}).slice(0, 2);
const latestPosts = allPosts.slice(0, 8);
const analysisPosts = allPosts.filter(p => p.data.category === 'تحليل').slice(0, 3);
const futurePosts = allPosts.filter(p => p.data.category === 'مستقبل').slice(0, 3);

let latestNews: any[] = [];
try {
  const now = new Date();
  const cutoffUnlinked = new Date();
  cutoffUnlinked.setDate(now.getDate() - 14);
  const cutoffLinked = new Date();
  cutoffLinked.setDate(now.getDate() - 60);

  latestNews = (await getCollection('news'))
    .flatMap((e: any) => e.data)
    .filter((n: any) => {
      if (n.draft) return false;
      const itemDate = new Date(n.date);
      if (n.articleSlug) {
        return itemDate >= cutoffLinked;
      }
      return itemDate >= cutoffUnlinked;
    })
    .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime())
    .slice(0, 6);
} catch { latestNews = []; }
---

<BaseLayout title="الرئيسية" lang={lang}>
  <Hero lang={lang} />

  <!-- Latest News -->
  {latestNews.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 py-12">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl md:text-2xl font-bold text-white flex items-center gap-3">
          <span class="w-8 h-8 rounded-lg bg-red-500/10 flex items-center justify-center">
            <span class="w-2 h-2 rounded-full bg-red-500 animate-pulse"></span>
          </span>
          <span>{t(lang, 'news.latest')}</span>
        </h2>
        <a href="/ar/news/" class="text-sm text-neon-blue hover:text-neon-green transition-colors flex items-center gap-1">
          {t(lang, 'news.viewAll')}
          <svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
      <div class="columns-1 md:columns-2 lg:columns-3 gap-4 space-y-4">
        {latestNews.map((item, index) => (
          <div class={index >= 3 ? 'hidden md:block break-inside-avoid' : 'break-inside-avoid'}>
            <NewsCard
              headline={item.headline}
              summary={item.summary}
              date={item.date}
              source={item.source}
              sourceUrl={item.sourceUrl}
              articleSlug={item.articleSlug}
              company={item.company}
              lang={lang}
            />
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Featured Articles -->
  <section class="max-w-7xl mx-auto px-4 py-16">
    <div class="flex items-center justify-between mb-8">
      <h2 class="section-title flex items-center gap-3">
        <span class="w-8 h-8 rounded-lg bg-neon-blue/10 flex items-center justify-center">
          <svg class="w-4 h-4 text-neon-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
          </svg>
        </span>
        <span class="gradient-text">{t(lang, 'section.featured')}</span>
      </h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {featuredPosts.map(post => (
        <ArticleCard
          title={post.data.title}
          description={post.data.description}
          date={post.data.date}
          category={post.data.category}
          slug={post.slug}
          image={post.data.image}
          featured={true}
          lang={lang}
        />
      ))}
    </div>
  </section>

  <!-- Latest News -->
  <section class="max-w-7xl mx-auto px-4 py-16">
    <div class="flex items-center justify-between mb-8">
      <h2 class="section-title flex items-center gap-3">
        <span class="w-8 h-8 rounded-lg bg-neon-green/10 flex items-center justify-center">
          <svg class="w-4 h-4 text-neon-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
          </svg>
        </span>
        <span>{t(lang, 'section.latest')}</span>
      </h2>
      <a href="/ar/blog/" class="text-sm text-neon-blue hover:text-neon-green transition-colors flex items-center gap-1">
        {t(lang, 'section.viewAll')}
        <svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {latestPosts.map(post => (
        <ArticleCard
          title={post.data.title}
          description={post.data.description}
          date={post.data.date}
          category={post.data.category}
          slug={post.slug}
          image={post.data.image}
          lang={lang}
        />
      ))}
    </div>
  </section>

  <!-- Deep Analysis -->
  {analysisPosts.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 py-16">
      <div class="flex items-center justify-between mb-8">
        <h2 class="section-title flex items-center gap-3">
          <span class="w-8 h-8 rounded-lg bg-purple-500/10 flex items-center justify-center">
            <svg class="w-4 h-4 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </span>
          <span>{t(lang, 'section.analysis')}</span>
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {analysisPosts.map(post => (
          <ArticleCard title={post.data.title} description={post.data.description} date={post.data.date} category={post.data.category} slug={post.slug} image={post.data.image} lang={lang} />
        ))}
      </div>
    </section>
  )}

  <!-- Future Predictions -->
  {futurePosts.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 py-16">
      <div class="flex items-center justify-between mb-8">
        <h2 class="section-title flex items-center gap-3">
          <span class="w-8 h-8 rounded-lg bg-pink-500/10 flex items-center justify-center">
            <svg class="w-4 h-4 text-pink-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
            </svg>
          </span>
          <span>{t(lang, 'section.future')}</span>
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {futurePosts.map(post => (
          <ArticleCard title={post.data.title} description={post.data.description} date={post.data.date} category={post.data.category} slug={post.slug} image={post.data.image} lang={lang} />
        ))}
      </div>
    </section>
  )}

  <!-- CTA Section -->
  <section class="max-w-7xl mx-auto px-4 py-16">
    <div class="glass-card p-10 md:p-16 text-center relative overflow-hidden">
      <div class="orb orb-blue w-64 h-64 -top-32 -right-32"></div>
      <div class="orb orb-green w-48 h-48 -bottom-24 -left-24"></div>
      <div class="relative z-10">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">{t(lang, 'cta.title')}</h2>
        <p class="text-gray-400 mb-8 max-w-lg mx-auto">{t(lang, 'cta.subtitle')}</p>
        <a href="/ar/blog/" class="btn-primary">
          {t(lang, 'cta.button')}
          <svg class="w-5 h-5 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
