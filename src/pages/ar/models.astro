---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ModelCard from '../../components/ModelCard.astro';
import { languageModels, imageModels, videoModels } from '../../data/models-ar';

const lang = 'ar';

const tierRank = { flagship: 0, standard: 1, budget: 2 } as const;

function sortModels(models: typeof languageModels) {
  return [...models].sort((a, b) => {
    const tierDiff = tierRank[a.tier] - tierRank[b.tier];
    if (tierDiff !== 0) return tierDiff;
    return b.releaseDateISO.localeCompare(a.releaseDateISO);
  });
}

const sortedLanguageModels = sortModels(languageModels);
const sortedImageModels = sortModels(imageModels);
const sortedVideoModels = sortModels(videoModels);

const allModels = [...sortedLanguageModels, ...sortedImageModels, ...sortedVideoModels];
---

<BaseLayout title="النماذج العالمية" description="دليل شامل لأهم وأحدث نماذج الذكاء الاصطناعي الرائدة عالمياً مع مواصفاتها ونقاط قوتها وتقييماتها المرجعية" lang={lang}>
  <div class="max-w-7xl mx-auto px-4 py-12">
    <!-- Header -->
    <div class="mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">
        أقوى نماذج <span class="gradient-text">الذكاء الاصطناعي (أبريل 2026)</span>
      </h1>
      <p class="text-gray-400 text-lg max-w-2xl">
        استعرض قائمة أقوى النماذج الصينية والعالمية التي تتصدر المؤشرات حالياً، اضغط على النموذج لقراءة التحليل التقييمي المفصل له.
      </p>
    </div>

    <!-- ===== القسم 1: النماذج اللغوية والمتعددة الوسائط ===== -->
    <section class="mb-20">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-2 flex items-center gap-3">
        <span class="w-10 h-10 rounded-xl bg-blue-500/10 flex items-center justify-center">
          <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" /></svg>
        </span>
        النماذج اللغوية والمتعددة الوسائط
      </h2>
      <p class="text-gray-500 text-sm mb-8 mr-13">نماذج المحادثة والاستدلال والبرمجة — مقارنة على معايير AIME, GPQA Diamond, SWE-bench</p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-10">
        {sortedLanguageModels.map((model) => (
          <ModelCard {...model} lang={lang} />
        ))}
      </div>

      <!-- جدول التقييم اللغوي -->
      <div class="glass-card overflow-hidden overflow-x-auto" style="background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); border: 1px solid rgba(99,179,237,0.12); border-radius: 16px;">
        <div style="padding: 24px 24px 8px 24px;">
          <p style="color: #94a3b8; font-size: 13px; text-align: center; margin: 0 0 20px 0; letter-spacing: 0.05em;">التقييمات المرجعية للنماذج اللغوية — أبريل 2026</p>
        </div>
        <table class="w-full text-sm text-right align-middle">
          <thead>
            <tr class="border-b border-dark-500/30">
              <th class="p-4 text-white font-semibold whitespace-nowrap">النموذج</th>
              <th class="p-4 text-white font-semibold">الشركة</th>
              <th class="p-4 text-center font-semibold" style="color: #60a5fa;">AIME 2025</th>
              <th class="p-4 text-center font-semibold" style="color: #a78bfa;">GPQA Diamond</th>
              <th class="p-4 text-center font-semibold" style="color: #34d399;">SWE-bench</th>
            </tr>
          </thead>
          <tbody>
            {languageModels.sort((a, b) => (b.benchmarks?.swe || 0) - (a.benchmarks?.swe || 0)).map((model, i) => (
              <tr class:list={['border-b border-dark-500/10 hover:bg-white/5 transition-colors', i % 2 === 0 ? 'bg-white/[0.02]' : '']}>
                <td class="p-4">
                  <a href={`/ar/blog/${model.slug}/`} class="text-neon-blue font-medium hover:underline hover:text-neon-green transition-colors">{model.name}</a>
                </td>
                <td class="p-4 text-gray-400 text-xs">{model.company}</td>
                <td class="p-4" style="min-width: 140px;">
                  <div style="display: flex; justify-content: space-between; margin-bottom: 3px;">
                    <span style="font-size: 11px; color: #94a3b8;">رياضيات</span>
                    <span style={`font-size: 12px; font-weight: 700; color: ${model.benchmarks.aime >= 93 ? '#60a5fa' : '#94a3b8'};`}>{model.benchmarks.aime}%</span>
                  </div>
                  <div style="background: rgba(255,255,255,0.06); border-radius: 4px; height: 6px; overflow: hidden;">
                    <div style={`width: ${model.benchmarks.aime}%; height: 100%; background: linear-gradient(90deg, #3b82f6, #60a5fa); border-radius: 4px;`}></div>
                  </div>
                </td>
                <td class="p-4" style="min-width: 140px;">
                  <div style="display: flex; justify-content: space-between; margin-bottom: 3px;">
                    <span style="font-size: 11px; color: #94a3b8;">علوم</span>
                    <span style={`font-size: 12px; font-weight: 700; color: ${model.benchmarks.gpqa >= 86 ? '#a78bfa' : '#94a3b8'};`}>{model.benchmarks.gpqa}%</span>
                  </div>
                  <div style="background: rgba(255,255,255,0.06); border-radius: 4px; height: 6px; overflow: hidden;">
                    <div style={`width: ${model.benchmarks.gpqa}%; height: 100%; background: linear-gradient(90deg, #7c3aed, #a78bfa); border-radius: 4px;`}></div>
                  </div>
                </td>
                <td class="p-4" style="min-width: 140px;">
                  <div style="display: flex; justify-content: space-between; margin-bottom: 3px;">
                    <span style="font-size: 11px; color: #94a3b8;">برمجة</span>
                    <span style={`font-size: 12px; font-weight: 700; color: ${model.benchmarks.swe >= 70 ? '#34d399' : '#94a3b8'};`}>{model.benchmarks.swe}%</span>
                  </div>
                  <div style="background: rgba(255,255,255,0.06); border-radius: 4px; height: 6px; overflow: hidden;">
                    <div style={`width: ${model.benchmarks.swe}%; height: 100%; background: linear-gradient(90deg, #059669, #34d399); border-radius: 4px;`}></div>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
        <div style="display: flex; gap: 20px; padding: 16px 24px; border-top: 1px solid rgba(255,255,255,0.05);">
          <div style="display: flex; align-items: center; gap: 6px;"><div style="width: 10px; height: 10px; border-radius: 3px; background: #60a5fa;"></div><span style="color: #64748b; font-size: 11px;">AIME (رياضيات)</span></div>
          <div style="display: flex; align-items: center; gap: 6px;"><div style="width: 10px; height: 10px; border-radius: 3px; background: #a78bfa;"></div><span style="color: #64748b; font-size: 11px;">GPQA (علوم)</span></div>
          <div style="display: flex; align-items: center; gap: 6px;"><div style="width: 10px; height: 10px; border-radius: 3px; background: #34d399;"></div><span style="color: #64748b; font-size: 11px;">SWE-bench (برمجة)</span></div>
        </div>
      </div>
    </section>

    <!-- ===== القسم 2: نماذج إنتاج الصور ===== -->
    <section class="mb-20">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-2 flex items-center gap-3">
        <span class="w-10 h-10 rounded-xl bg-amber-500/10 flex items-center justify-center">
          <svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
        </span>
        نماذج إنتاج الصور
      </h2>
      <p class="text-gray-500 text-sm mb-8 mr-13">نماذج توليد الصور بالذكاء الاصطناعي — مقارنة على ELO Score, الالتزام بالوصف, الواقعية</p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-10">
        {sortedImageModels.map((model) => (
          <ModelCard {...model} lang={lang} />
        ))}
      </div>

      <!-- جدول تقييم الصور -->
      <div class="glass-card overflow-hidden overflow-x-auto" style="background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); border: 1px solid rgba(245,158,11,0.12); border-radius: 16px;">
        <div style="padding: 24px 24px 8px 24px;">
          <p style="color: #94a3b8; font-size: 13px; text-align: center; margin: 0 0 20px 0; letter-spacing: 0.05em;">تقييمات نماذج الصور — Artificial Analysis أبريل 2026</p>
        </div>
        <table class="w-full text-sm text-right align-middle">
          <thead>
            <tr class="border-b border-dark-500/30">
              <th class="p-4 text-white font-semibold whitespace-nowrap">النموذج</th>
              <th class="p-4 text-white font-semibold">الشركة</th>
              <th class="p-4 text-center font-semibold" style="color: #fbbf24;">ELO Score</th>
              <th class="p-4 text-center font-semibold" style="color: #f97316;">الالتزام بالوصف</th>
              <th class="p-4 text-center font-semibold" style="color: #a78bfa;">الواقعية</th>
            </tr>
          </thead>
          <tbody>
            {imageModels.sort((a, b) => (b.benchmarks?.elo || 0) - (a.benchmarks?.elo || 0)).map((model, i) => (
              <tr class:list={['border-b border-dark-500/10 hover:bg-white/5 transition-colors', i % 2 === 0 ? 'bg-white/[0.02]' : '']}>
                <td class="p-4">
                  <a href={`/ar/blog/${model.slug}/`} class="text-amber-400 font-medium hover:underline hover:text-amber-300 transition-colors">{model.name}</a>
                </td>
                <td class="p-4 text-gray-400 text-xs">{model.company}</td>
                <td class="p-4" style="min-width: 140px;">
                  <div style="display: flex; justify-content: space-between; margin-bottom: 3px;">
                    <span style="font-size: 11px; color: #94a3b8;">ELO</span>
                    <span style="font-size: 12px; font-weight: 700; color: #fbbf24;">{model.benchmarks.elo}</span>
                  </div>
                  <div style="background: rgba(255,255,255,0.06); border-radius: 4px; height: 6px; overflow: hidden;">
                    <div style={`width: ${((model.benchmarks.elo - 1050) / (1300 - 1050)) * 100}%; height: 100%; background: linear-gradient(90deg, #d97706, #fbbf24); border-radius: 4px;`}></div>
                  </div>
                </td>
                <td class="p-4 text-center"><span style="color: #f97316; font-size: 13px; font-weight: 600;">{model.benchmarks.p || "N/A"}</span></td>
                <td class="p-4 text-center"><span style="color: #a78bfa; font-size: 13px; font-weight: 600;">{model.benchmarks.r || "N/A"}</span></td>
              </tr>
            ))}
          </tbody>
        </table>
        <div style="display: flex; gap: 20px; padding: 16px 24px; border-top: 1px solid rgba(255,255,255,0.05);">
          <div style="display: flex; align-items: center; gap: 6px;"><div style="width: 10px; height: 10px; border-radius: 3px; background: #fbbf24;"></div><span style="color: #64748b; font-size: 11px;">ELO (تفضيل بشري)</span></div>
          <div style="display: flex; align-items: center; gap: 6px;"><div style="width: 10px; height: 10px; border-radius: 3px; background: #f97316;"></div><span style="color: #64748b; font-size: 11px;">التزام بالوصف</span></div>
          <div style="display: flex; align-items: center; gap: 6px;"><div style="width: 10px; height: 10px; border-radius: 3px; background: #a78bfa;"></div><span style="color: #64748b; font-size: 11px;">واقعية فوتوغرافية</span></div>
        </div>
      </div>
    </section>

    <!-- ===== القسم 3: نماذج إنتاج الفيديو ===== -->
    <section class="mb-16">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-2 flex items-center gap-3">
        <span class="w-10 h-10 rounded-xl bg-pink-500/10 flex items-center justify-center">
          <svg class="w-5 h-5 text-pink-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
        </span>
        نماذج إنتاج الفيديو
      </h2>
      <p class="text-gray-500 text-sm mb-8 mr-13">نماذج توليد الفيديو السينمائي — مقارنة على الواقعية, جودة الصوت, التحكم السينمائي</p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-10">
        {sortedVideoModels.map((model) => (
          <ModelCard {...model} lang={lang} />
        ))}
      </div>

      <!-- جدول تقييم الفيديو -->
      <div class="glass-card overflow-hidden overflow-x-auto" style="background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); border: 1px solid rgba(236,72,153,0.12); border-radius: 16px;">
        <div style="padding: 24px 24px 8px 24px;">
          <p style="color: #94a3b8; font-size: 13px; text-align: center; margin: 0 0 20px 0; letter-spacing: 0.05em;">تقييمات نماذج الفيديو — Video Arena أبريل 2026</p>
        </div>
        <table class="w-full text-sm text-right align-middle">
          <thead>
            <tr class="border-b border-dark-500/30">
              <th class="p-4 text-white font-semibold whitespace-nowrap">النموذج</th>
              <th class="p-4 text-white font-semibold">الشركة</th>
              <th class="p-4 text-center font-semibold" style="color: #f472b6;">الواقعية</th>
              <th class="p-4 text-center font-semibold" style="color: #22d3ee;">جودة الصوت</th>
              <th class="p-4 text-center font-semibold" style="color: #a78bfa;">التحكم السينمائي</th>
            </tr>
          </thead>
          <tbody>
            {videoModels.map((model, i) => (
              <tr class:list={['border-b border-dark-500/10 hover:bg-white/5 transition-colors', i % 2 === 0 ? 'bg-white/[0.02]' : '']}>
                <td class="p-4">
                  <a href={`/ar/blog/${model.slug}/`} class="text-pink-400 font-medium hover:underline hover:text-pink-300 transition-colors">{model.name}</a>
                </td>
                <td class="p-4 text-gray-400 text-xs">{model.company}</td>
                <td class="p-4 text-center"><span style="color: #f472b6; font-size: 13px; font-weight: 600;">{model.benchmarks.r || "N/A"}</span></td>
                <td class="p-4 text-center"><span style="color: #0891b2; font-size: 12px; font-weight: 600;">{model.benchmarks.a || "N/A"}</span></td>
                <td class="p-4 text-center"><span style="color: #a78bfa; font-size: 13px; font-weight: 600;">{model.benchmarks.c || "N/A"}</span></td>
              </tr>
            ))}
          </tbody>
        </table>
        <div style="display: flex; gap: 20px; padding: 16px 24px; border-top: 1px solid rgba(255,255,255,0.05);">
          <div style="display: flex; align-items: center; gap: 6px;"><div style="width: 10px; height: 10px; border-radius: 3px; background: #f472b6;"></div><span style="color: #64748b; font-size: 11px;">واقعية بصرية</span></div>
          <div style="display: flex; align-items: center; gap: 6px;"><div style="width: 10px; height: 10px; border-radius: 3px; background: #22d3ee;"></div><span style="color: #64748b; font-size: 11px;">جودة الصوت</span></div>
          <div style="display: flex; align-items: center; gap: 6px;"><div style="width: 10px; height: 10px; border-radius: 3px; background: #a78bfa;"></div><span style="color: #64748b; font-size: 11px;">التحكم السينمائي</span></div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
