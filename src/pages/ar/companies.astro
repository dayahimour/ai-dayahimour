---
import BaseLayout from '../../layouts/BaseLayout.astro';

const lang = 'ar';

const companies = [
  { name: 'OpenAI', description: 'مختبر أبحاث الذكاء الاصطناعي الأشهر عالمياً — صانعة GPT و ChatGPT و DALL·E و Sora.', logo: '/icons/openai.svg', founded: '2015', hq: 'سان فرانسيسكو، أمريكا', slug: 'openai', color: '#10a37f' },
  { name: 'Anthropic', description: 'شركة أمان الذكاء الاصطناعي — صانعة Claude، تركز على بناء نماذج آمنة وموثوقة.', logo: '/icons/anthropic.svg', founded: '2021', hq: 'سان فرانسيسكو، أمريكا', slug: 'anthropic', color: '#d4a574' },
  { name: 'Google DeepMind', description: 'ذراع الذكاء الاصطناعي لغوغل — صانعة Gemini و AlphaGo و Veo و Imagen.', logo: '/icons/google-color.svg', founded: '2010', hq: 'لندن، بريطانيا', slug: 'google-deepmind', color: '#4285f4' },
  { name: 'Meta AI', description: 'قسم الذكاء الاصطناعي في ميتا — صانعة Llama مفتوح المصدر و SAM و NLLB.', logo: '/icons/meta-color.svg', founded: '2013', hq: 'مينلو بارك، أمريكا', slug: 'meta-ai', color: '#0668E1' },
  { name: 'DeepSeek', description: 'الشركة الصينية التي أذهلت العالم — نماذج منافسة بتكلفة أقل 95%.', logo: '/icons/deepseek-color.svg', founded: '2023', hq: 'هانغزو، الصين', slug: 'deepseek', color: '#4D6BFE' },
  { name: 'xAI', description: 'شركة إيلون ماسك للذكاء الاصطناعي — صانعة Grok مع وصول حي لبيانات X.', logo: '/icons/xai.svg', founded: '2023', hq: 'أوستن، أمريكا', slug: 'xai', color: '#fff' },
  { name: 'Alibaba Cloud (Qwen)', description: 'ذراع الحوسبة السحابية لعلي بابا — صانعة نماذج Qwen المفتوحة المصدر.', logo: '/icons/qwen-color.svg', founded: '2009', hq: 'هانغزو، الصين', slug: 'alibaba-qwen', color: '#ff6a00' },
  { name: 'ByteDance', description: 'عملاق التكنولوجيا الصيني (TikTok) — صانعة Seedream و Seedance و Doubao.', logo: '/icons/bytedance-color.svg', founded: '2012', hq: 'بكين، الصين', slug: 'bytedance', color: '#325AB4' },
  { name: 'Microsoft', description: 'شريك OpenAI الاستراتيجي — مُدمجة AI في كل منتجاتها عبر Copilot.', logo: '/icons/microsoft-color.svg', founded: '1975', hq: 'ريدموند، أمريكا', slug: 'microsoft', color: '#00a4ef' },
  { name: 'NVIDIA', description: 'ملكة الرقائق — صانعة وحدات GPU التي تشغّل كل نماذج الذكاء الاصطناعي.', logo: '/icons/nvidia-color.svg', founded: '1993', hq: 'سانتا كلارا، أمريكا', slug: 'nvidia', color: '#76b900' },
  { name: 'Xiaomi (MiMo)', description: 'عملاق الإلكترونيات الصيني يدخل سباق AI بنموذج MiMo الوكيلي.', logo: '/icons/xiaomimimo.svg', founded: '2010', hq: 'بكين، الصين', slug: 'xiaomi-mimo', color: '#ff6900' },
  { name: 'MiniMax', description: 'شركة صينية تنافس بنماذج MoE فعالة بتكلفة أقل 20 مرة من Claude.', logo: '/icons/minimax-color.svg', founded: '2021', hq: 'شانغهاي، الصين', slug: 'minimax', color: '#5B6CFF' },
  { name: 'Zhipu AI', description: 'شركة صينية رائدة — صانعة GLM و ChatGLM للاستخدام العام والبرمجة.', logo: '/icons/zhipu-color.svg', founded: '2019', hq: 'بكين، الصين', slug: 'zhipu-ai', color: '#4B5FD6' },
  { name: 'Moonshot AI (Kimi)', description: 'شركة صينية ناشئة — صانعة Kimi المتفوق في الرياضيات والبرمجة.', logo: '/icons/kimi-color.svg', founded: '2023', hq: 'بكين، الصين', slug: 'moonshot-ai', color: '#4F46E5' },
  { name: 'StepFun', description: 'شركة صينية تقدم نماذج مجانية وسريعة للمهام البسيطة.', logo: '/icons/stepfun-color.svg', founded: '2023', hq: 'شانغهاي، الصين', slug: 'stepfun', color: '#6366f1' },
  { name: 'Stability AI', description: 'رائدة الصور المفتوحة المصدر — صانعة Stable Diffusion.', logo: '/icons/stability-color.svg', founded: '2019', hq: 'لندن، بريطانيا', slug: 'stability-ai', color: '#A855F7' },
  { name: 'Midjourney', description: 'أفضل نموذج فني إبداعي لتوليد الصور بأسلوب سينمائي مذهل.', logo: '/icons/midjourney.svg', founded: '2021', hq: 'سان فرانسيسكو، أمريكا', slug: 'midjourney', color: '#fff' },
  { name: 'Black Forest Labs (FLUX)', description: 'فريق Stable Diffusion السابق — صانعة FLUX الأعلى جودة فنية.', logo: '/icons/bfl.svg', founded: '2024', hq: 'فرايبورغ، ألمانيا', slug: 'black-forest-labs', color: '#fff' },
  { name: 'RunwayML', description: 'رائدة الفيديو الإبداعي بالذكاء الاصطناعي — صانعة Gen-1 إلى Gen-4.5.', logo: '/icons/runway.svg', founded: '2018', hq: 'نيويورك، أمريكا', slug: 'runwayml', color: '#fff' },
  { name: 'Kuaishou (Kling)', description: 'عملاق الفيديو القصير الصيني — صانعة Kling لتوليد الفيديو.', logo: '/icons/kling-color.svg', founded: '2011', hq: 'بكين، الصين', slug: 'kuaishou', color: '#FF4906' },
  { name: 'Mistral AI', description: 'شركة فرنسية رائدة — نماذج مفتوحة المصدر منافسة عالمياً.', logo: '/icons/mistral-color.svg', founded: '2023', hq: 'باريس، فرنسا', slug: 'mistral-ai', color: '#FF7000' },
  { name: 'Perplexity AI', description: 'محرك البحث الذكي الذي ينافس Google بإجابات مباشرة مدعومة بالمصادر.', logo: '/icons/perplexity-color.svg', founded: '2022', hq: 'سان فرانسيسكو، أمريكا', slug: 'perplexity-ai', color: '#20808D' },
  { name: 'Cohere', description: 'شركة كندية متخصصة في نماذج المؤسسات والبحث الدلالي.', logo: '/icons/cohere-color.svg', founded: '2019', hq: 'تورنتو، كندا', slug: 'cohere', color: '#39594D' },
  { name: 'Hugging Face', description: 'أكبر منصة مجتمعية لمشاركة النماذج المفتوحة المصدر.', logo: '/icons/huggingface-color.svg', founded: '2016', hq: 'نيويورك، أمريكا', slug: 'hugging-face', color: '#FFD21E' },
];
---

<BaseLayout title="الشركات" description="دليل شامل لأهم شركات الذكاء الاصطناعي في العالم — من التأسيس إلى النجاح" lang={lang}>
  <div class="max-w-7xl mx-auto px-4 py-12">
    <div class="mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">
        شركات <span class="gradient-text">الذكاء الاصطناعي</span>
      </h1>
      <p class="text-gray-400 text-lg max-w-2xl">
        تعرّف على أبرز الشركات التي تقود ثورة الذكاء الاصطناعي عالمياً — من وادي السيليكون إلى الصين وأوروبا
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {companies.map(company => (
        <a href={`/ar/blog/${company.slug}`} class="glass-card p-6 hover:border-white/20 transition-all group block">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-14 h-14 rounded-xl bg-white/5 flex items-center justify-center p-2 group-hover:bg-white/10 transition-colors">
              <img src={company.logo} alt={company.name} class="w-10 h-10 object-contain" loading="lazy" />
            </div>
            <div>
              <h3 class="text-lg font-bold text-white group-hover:text-neon-blue transition-colors">{company.name}</h3>
              <p class="text-xs text-gray-500">تأسست {company.founded} · {company.hq}</p>
            </div>
          </div>
          <p class="text-gray-400 text-sm leading-relaxed">{company.description}</p>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
