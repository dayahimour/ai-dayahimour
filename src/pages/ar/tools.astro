---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/ToolCard.astro';

const lang = 'ar';

const tools = [
  // --- وكلاء البرمجة (AI Coding Agents) ---
  {
    name: 'OpenClaw',
    description: 'الوكيل الذكي الذي ينفذ المهام فعلياً — يتصفح الويب، يدير الملفات، وينفذ الأوامر بشكل مستقل.',
    category: 'وكيل',
    icon: '🦞',
    slug: 'openclaw',
    logo: '/icons/openclaw-color.svg',
    tokens: '6.39T',
  },
  {
    name: 'Kilo Code',
    description: 'وكيل برمجة ذكي لـ VS Code — يكتب الكود، يراجع الأخطاء، ويقترح تحسينات تلقائياً.',
    category: 'برمجة',
    icon: '⚡',
    slug: 'kilo-code',
    logo: '/icons/kilocode.svg',
    tokens: '2.18T',
  },
  {
    name: 'Claude Code',
    description: 'مساعد Anthropic لحل المشكلات المعقدة — يحلل الكود، يصمم الحلول، ويشرح المفاهيم بوضوح.',
    category: 'برمجة',
    icon: '🎯',
    slug: 'claude-code',
    logo: '/icons/claudecode-color.svg',
    tokens: '920B',
  },
  {
    name: 'Cline',
    description: 'وكيل برمجة مستقل يعمل مباشرة في بيئة التطوير — يكتب، يختبر، ويصحح الكود ذاتياً.',
    category: 'برمجة',
    icon: '🤖',
    slug: 'cline',
    logo: '/icons/cline.svg',
    tokens: '682B',
  },
  {
    name: 'Roo Code',
    description: 'فريق تطوير كامل من وكلاء AI — يدير المشاريع الكبيرة بتقسيم المهام بين وكلاء متخصصين.',
    category: 'برمجة',
    icon: '🦘',
    slug: 'roo-code',
    logo: '/icons/roocode.svg',
    tokens: '125B',
  },

  // --- أدوات الإبداع والمحتوى ---
  {
    name: 'Descript',
    description: 'محرر فيديو وبودكاست بالذكاء الاصطناعي — عدّل الفيديو بتعديل النص، استنسخ الأصوات، وأزل الكلمات.',
    category: 'فيديو',
    icon: '🎬',
    slug: 'descript',
    tokens: '289B',
  },

  // --- وكلاء المهام العامة ---
  {
    name: 'Hermes Agent',
    description: 'وكيل ذكي لتبسيط المهام المعقدة — يربط بين التطبيقات وينفذ سير عمل تلقائي.',
    category: 'وكيل',
    icon: '📨',
    slug: 'hermes-agent',
    tokens: '280B',
    isNew: true,
  },
  {
    name: 'Janitor AI',
    description: 'منصة شخصيات افتراضية مذهلة — محادثات تفاعلية مع شخصيات AI مخصصة للترفيه والإبداع.',
    category: 'محادثة',
    icon: '🧹',
    slug: 'janitor-ai',
    tokens: '207B',
  },
  {
    name: 'ISEKAI ZERO',
    description: 'مغامرات AI تفاعلية — سافر إلى عوالم خيالية وتفاعل مع شخصيات وقصص مولدة بالذكاء الاصطناعي.',
    category: 'ألعاب',
    icon: '⚔️',
    slug: 'isekai-zero',
    tokens: '206B',
  },
  {
    name: 'Lemonade',
    description: 'أداة AI لألعاب Roblox — أنشئ عوالم وشخصيات وألعاب كاملة باستخدام الذكاء الاصطناعي.',
    category: 'ألعاب',
    icon: '🍋',
    slug: 'lemonade',
    tokens: '68.8B',
  },
];
---

<BaseLayout title="أدوات AI" description="دليل شامل لأفضل أدوات ووكلاء الذكاء الاصطناعي في 2026" lang={lang}>
  <div class="max-w-7xl mx-auto px-4 py-12">
    <!-- Header -->
    <div class="mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">
        أدوات ووكلاء <span class="gradient-text">الذكاء الاصطناعي</span>
      </h1>
      <p class="text-gray-400 text-lg max-w-2xl">
        اكتشف أفضل أدوات AI ووكلاء البرمجة التي ستحسن إنتاجيتك — من وكلاء الكود إلى أدوات الإبداع والمحتوى
      </p>
    </div>

    <!-- Tools Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {tools.map(tool => (
        <ToolCard {...tool} lang={lang} />
      ))}
    </div>
  </div>
</BaseLayout>
