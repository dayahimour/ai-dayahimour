---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const featuredPosts = allPosts.filter(p => p.data.featured).slice(0, 2);
const latestPosts = allPosts.slice(0, 8);
const analysisPosts = allPosts.filter(p => p.data.category === 'تحليل').slice(0, 3);
const futurePosts = allPosts.filter(p => p.data.category === 'مستقبل').slice(0, 3);

// Prepare posts data for client-side randomization
const postsData = allPosts.map(post => ({
  title: post.data.title,
  description: post.data.description,
  date: post.data.date,
  category: post.data.category,
  slug: post.slug,
  image: post.data.image || '',
  featured: post.data.featured,
}));
---

<BaseLayout title="الرئيسية">
  <!-- Hero -->
  <Hero />

  <!-- Featured Articles -->
  <section class="max-w-7xl mx-auto px-4 py-16">
    <div class="flex items-center justify-between mb-8">
      <h2 class="section-title flex items-center gap-3">
        <span class="w-8 h-8 rounded-lg bg-neon-blue/10 flex items-center justify-center">
          <svg class="w-4 h-4 text-neon-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
          </svg>
        </span>
        <span class="gradient-text">مقالات مميزة</span>
      </h2>
    </div>
    <div id="featured-posts-container" class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {featuredPosts.map(post => (
        <ArticleCard
          title={post.data.title}
          description={post.data.description}
          date={post.data.date}
          category={post.data.category}
          slug={post.slug}
          image={post.data.image}
          featured={true}
        />
      ))}
    </div>
  </section>

  <!-- Latest News -->
  <section class="max-w-7xl mx-auto px-4 py-16">
    <div class="flex items-center justify-between mb-8">
      <h2 class="section-title flex items-center gap-3">
        <span class="w-8 h-8 rounded-lg bg-neon-green/10 flex items-center justify-center">
          <svg class="w-4 h-4 text-neon-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
          </svg>
        </span>
        <span>آخر المقالات</span>
      </h2>
      <a href="/blog" class="text-sm text-neon-blue hover:text-neon-green transition-colors flex items-center gap-1">
        عرض الكل
        <svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {latestPosts.map(post => (
        <ArticleCard
          title={post.data.title}
          description={post.data.description}
          date={post.data.date}
          category={post.data.category}
          slug={post.slug}
          image={post.data.image}
        />
      ))}
    </div>
  </section>

  <!-- Deep Analysis -->
  {analysisPosts.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 py-16">
      <div class="flex items-center justify-between mb-8">
        <h2 class="section-title flex items-center gap-3">
          <span class="w-8 h-8 rounded-lg bg-purple-500/10 flex items-center justify-center">
            <svg class="w-4 h-4 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </span>
          <span>تحليلات عميقة</span>
        </h2>
        <a href="/blog" class="text-sm text-neon-blue hover:text-neon-green transition-colors flex items-center gap-1">
          عرض الكل
          <svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {analysisPosts.map(post => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            category={post.data.category}
            slug={post.slug}
            image={post.data.image}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Future Predictions -->
  {futurePosts.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 py-16">
      <div class="flex items-center justify-between mb-8">
        <h2 class="section-title flex items-center gap-3">
          <span class="w-8 h-8 rounded-lg bg-pink-500/10 flex items-center justify-center">
            <svg class="w-4 h-4 text-pink-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
            </svg>
          </span>
          <span>تنبؤات المستقبل</span>
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {futurePosts.map(post => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            category={post.data.category}
            slug={post.slug}
            image={post.data.image}
          />
        ))}
      </div>
    </section>
  )}

  <!-- CTA Section -->
  <section class="max-w-7xl mx-auto px-4 py-16">
    <div class="glass-card p-10 md:p-16 text-center relative overflow-hidden">
      <div class="orb orb-blue w-64 h-64 -top-32 -right-32"></div>
      <div class="orb orb-green w-48 h-48 -bottom-24 -left-24"></div>
      <div class="relative z-10">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">ابق على اطلاع دائم</h2>
        <p class="text-gray-400 mb-8 max-w-lg mx-auto">
          تابع أحدث التطورات في عالم الذكاء الاصطناعي. محتوى جديد كل يوم!
        </p>
        <a href="/blog" class="btn-primary">
          تصفح جميع المقالات
          <svg class="w-5 h-5 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <script>
    // Randomize featured posts for each user
    (function() {
      try {
        const featuredPosts = JSON.parse(document.getElementById('posts-data')?.textContent || '[]');
        const featuredPostsFiltered = featuredPosts.filter(post => post.featured);
        
        if (featuredPostsFiltered.length <= 2) return;
        
        // Shuffle array using Fisher-Yates algorithm
        function shuffleArray(array) {
          for (let i = array.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [array[i], array[j]] = [array[j], array[i]];
          }
          return array;
        }
        
        const shuffledPosts = shuffleArray([...featuredPostsFiltered]).slice(0, 2);
        const container = document.getElementById('featured-posts-container');
        
        if (container) {
          container.innerHTML = shuffledPosts.map(post => `
            <a href="/blog/${post.slug}" class="group block md:col-span-2">
              <article class="glass-card overflow-hidden h-full flex flex-col">
                <div class="relative overflow-hidden h-56 md:h-72">
                  ${post.image ? `
                    <img
                      src="${post.image}"
                      alt="${post.title}"
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                      loading="lazy"
                    />
                  ` : `
                    <div class="w-full h-full bg-gradient-to-br from-dark-600 to-dark-700 flex items-center justify-center">
                      <svg class="w-16 h-16 text-dark-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />
                      </svg>
                    </div>
                  `}
                  <div class="absolute inset-0 bg-gradient-to-t from-dark-900/80 to-transparent"></div>
                  <span class="absolute top-3 right-3 inline-block px-3 py-1 text-xs font-medium rounded-full border bg-neon-blue/10 text-neon-blue border-neon-blue/20">
                    ${post.category}
                  </span>
                </div>

                <div class="p-5 flex flex-col flex-1">
                  <h3 class="font-bold text-white mb-2 group-hover:text-neon-blue transition-colors leading-tight text-xl md:text-2xl">
                    ${post.title}
                  </h3>
                  <p class="text-sm text-gray-400 leading-relaxed mb-4 flex-1 line-clamp-2">
                    ${post.description}
                  </p>
                  <div class="flex items-center justify-between text-xs text-gray-500">
                    <span>${new Date(post.date).toLocaleDateString('ar-EG', {
                      year: 'numeric',
                      month: 'short',
                      day: 'numeric'
                    })}</span>
                    <span class="flex items-center gap-1 text-neon-blue group-hover:gap-2 transition-all">
                      اقرأ المزيد
                      <svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                      </svg>
                    </span>
                  </div>
                </div>
              </article>
            </a>
          `).join('');
        }
      } catch (error) {
        console.error('Error randomizing featured posts:', error);
      }
    })();
  </script>
  
  <script id="posts-data" type="application/json">
    ${JSON.stringify(postsData)}
  </script>
</BaseLayout>
