---
// Root portal: used as static fallback when Worker/middleware are not active.
// Bots see hreflang links + content (no redirect). Humans get JS redirect.
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const lang = 'x-default';

// Fetch some latest posts for bot indexing and SEO value (AdSense approval)
const allPosts = (await getCollection('blog'))
  .filter((post: any) => !post.data.draft)
  .sort((a: any, b: any) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 8);
---
<!DOCTYPE html>
<html lang="x-default">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large" />
    <link rel="canonical" href="https://dayahimour.org/" />
    <link rel="alternate" hreflang="ar" href="https://dayahimour.org/ar/" />
    <link rel="alternate" hreflang="en" href="https://dayahimour.org/en/" />
    <link rel="alternate" hreflang="x-default" href="https://dayahimour.org/" />
    <title>AI DayaHimour — AI News &amp; Analysis</title>
    <meta name="description" content="Your go-to source for AI news, model analysis, tool reviews, and future predictions — covering ChatGPT, Claude, Gemini, and more." />

    <!-- OpenGraph for root -->
    <meta property="og:title" content="AI DayaHimour — AI News & Analysis" />
    <meta property="og:description" content="Daily AI news, deep analysis, model comparisons, and exclusive insights." />
    <meta property="og:image" content="https://dayahimour.org/images/og-default.png" />
    <meta property="og:url" content="https://dayahimour.org/" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:locale:alternate" content="ar_AR" />
    <meta property="og:site_name" content="AI DayaHimour" />

    <script is:inline>
      (function() {
        // Detect bots so we don't redirect them (vital for AdSense!)
        var ua = navigator.userAgent.toLowerCase();
        var isBot = /bot|googlebot|crawler|spider|robot|crawling|mediapartners|adsbot/i.test(ua);
        if (isBot) return;

        try {
          // 1. Cookie (user preference)
          var m = document.cookie.match(/lang=(ar|en)/);
          if (m) { window.location.replace('/' + m[1] + '/'); return; }
          // 2. Browser language — detect and store cookie for next visit
          var nav = (navigator.language || navigator.userLanguage || '').toLowerCase();
          var target = nav.startsWith('ar') ? '/ar/' : '/en/';
          document.cookie = 'lang=' + (nav.startsWith('ar') ? 'ar' : 'en') + ';path=/;max-age=31536000;SameSite=Strict;Secure';
          window.location.replace(target);
        } catch (e) {
          // If JS fails, show the manual links below
        }
      })();
    </script>

    <style>
      body {
        background-color: #050a12;
        color: #e5e7eb;
        font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
        margin: 0;
        padding: 0;
      }
      .hero-section {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 4rem 2rem;
        text-align: center;
        border-bottom: 1px solid #1e293b;
      }
      h1 { font-size: 2.5rem; margin-bottom: 0.5rem; color: #fff; }
      p.sub { color: #9ca3af; margin-bottom: 2rem; font-size: 1.1rem;}
      .links { display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center; }
      .btn {
        display: inline-flex; align-items: center; gap: 0.5rem;
        padding: 0.9rem 1.6rem; border-radius: 0.75rem; font-weight: 600;
        text-decoration: none; transition: transform 0.15s ease, box-shadow 0.15s ease;
      }
      .btn:hover { transform: translateY(-1px); }
      .btn-ar {
        background: linear-gradient(135deg, #3b82f6, #22c55e);
        color: #050a12;
      }
      .btn-en {
        background: #1f2937;
        color: #fff;
        border: 1px solid #374151;
      }
      .btn-en:hover { border-color: #60a5fa; }
      
      .content-section {
        max-width: 1200px;
        margin: 0 auto;
        padding: 4rem 2rem;
      }
      .post-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 1.5rem;
        margin-top: 2rem;
      }
      .post-card {
        background: #0f172a;
        border: 1px solid #1e293b;
        border-radius: 1rem;
        padding: 1.5rem;
      }
      .post-card h3 { margin: 0 0 1rem 0; color: #fff; font-size: 1.25rem; }
      .post-card p { color: #94a3b8; font-size: 0.9rem; line-height: 1.5; margin: 0; }
    </style>
  </head>
  <body>
    <div class="hero-section">
      <h1>AI DayaHimour</h1>
      <p class="sub">Explore the future of Artificial Intelligence</p>

      <div class="links">
        <a href="/ar/" class="btn btn-ar" lang="ar" dir="rtl">
          <span>العربية</span>
        </a>
        <a href="/en/" class="btn btn-en" lang="en">
          <span>English</span>
        </a>
      </div>
    </div>

    <!-- SEO & AdSense Content for Bots -->
    <div class="content-section">
      <h2 style="color: #fff; border-bottom: 1px solid #1e293b; padding-bottom: 1rem;">Latest AI Insights & News</h2>
      <p style="color: #6b7280; font-size: 0.95rem; margin-top: 1rem;">
        AI DayaHimour is your go-to source for AI news, model analysis, tool reviews, and future predictions. We cover ChatGPT, Claude, Gemini, and more in both Arabic and English.
      </p>
      
      <div class="post-grid">
        {allPosts.map((post: any) => (
          <article class="post-card">
            <h3><a href={`/en/blog/${post.slug}/`} style="color: inherit; text-decoration: none;">{post.data.title}</a></h3>
            <p>{post.data.description}</p>
          </article>
        ))}
      </div>
    </div>
  </body>
</html>
