---
// Root index: fallback redirect. Cloudflare Worker handles geo-redirect for production.
// This page is only hit if Worker is not active (dev mode).
---
<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="refresh" content="0;url=/ar/" />
    <link rel="canonical" href="https://dayahimour.org/ar/" />
    <title>Redirecting...</title>
    <script>
      // Client-side fallback: check browser language
      const lang = navigator.language || navigator.userLanguage || 'ar';
      const isArabic = lang.startsWith('ar');
      window.location.replace(isArabic ? '/ar/' : '/en/');
    </script>
  </head>
  <body>
    <p>Redirecting...</p>
  </body>
</html>
