<BaseLayout title="النماذج العالمية" description="دليل شامل لأهم وأحدث 10 نماذج ذكاء اصطناعي رائدة عالمياً مع مواصفاتها ونقاط قوتها">
  <div class="max-w-7xl mx-auto px-4 py-12">
    <!-- Header -->
    <div class="mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">
        أقوى نماذج <span class="gradient-text">الذكاء الاصطناعي (أبريل 2026)</span>
      </h1>
      <p class="text-gray-400 text-lg max-w-2xl">
        استعرض قائمة أقوى 10 نماذج صينية وعالمية تتصدر المؤشرات حالياً، اضغط على النموذج لقراءة التحليل التقييمي المفصل لها.
      </p>
    </div>

    <!-- Models Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
      {models.map((model) => (
        <ModelCard {...model} />
      ))}
    </div>

    <!-- Comparison Table -->
    <section>
      <h2 class="section-title flex items-center gap-3 mb-8">
        <span class="w-8 h-8 rounded-lg bg-neon-blue/10 flex items-center justify-center">
          <svg class="w-4 h-4 text-neon-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
          </svg>
        </span>
        جدول التقييم العالمي العام
      </h2>
      <div class="glass-card overflow-hidden overflow-x-auto">
        <table class="w-full text-sm text-right align-middle">
          <thead>
            <tr class="border-b border-dark-500/30 bg-dark-800/80">
              <th class="p-4 text-white font-semibold whitespace-nowrap">النموذج</th>
              <th class="p-4 text-white font-semibold">الشركة</th>
              <th class="p-4 text-white font-semibold">النوع</th>
              <th class="p-4 text-white font-semibold whitespace-nowrap">نظام القياس (Elo Rating)</th>
              <th class="p-4 text-white font-semibold">المميزات الرئيسية</th>
            </tr>
          </thead>
          <tbody>
            {models.map((model, i) => (
              <tr class:list={['border-b border-dark-500/20 hover:bg-white/5 transition-colors', i % 2 === 0 ? 'bg-dark-700/20' : '']}>
                <td class="p-4">
                  <a href={model.slug ? `/blog/${model.slug}` : '#'} class="text-neon-blue font-medium hover:underline hover:text-neon-green transition-colors">
                    {model.name}
                  </a>
                </td>
                <td class="p-4 text-gray-300">{model.company}</td>
                <td class="p-4">
                  <span class="px-2 py-1 bg-dark-600 rounded text-xs text-gray-300 font-medium">{model.type}</span>
                </td>
                <td class="p-4">
                  <span class="text-yellow-500 font-bold bg-yellow-500/10 px-2.5 py-1 rounded-full text-xs items-center gap-1 inline-flex">
                    🏆 {model.rating}
                  </span>
                </td>
                <td class="p-4 text-gray-400 text-xs">{model.strengths.slice(0, 3).join('، ')}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  </div>
</BaseLayout>
