// Helper to get bar color based on score
function getBarColor(score: number, category: string): string {
  if (category === 'math') return score >= 90 ? '#3b82f6' : '#60a5fa';
  if (category === 'science') return score >= 85 ? '#8b5cf6' : '#a78bfa';
  if (category === 'code') return score >= 70 ? '#059669' : '#34d399';
  if (category === 'image') return score >= 1200 ? '#f59e0b' : '#fbbf24';
  if (category === 'video') return score >= 90 ? '#ec4899' : '#f472b6';
  return '#60a5fa';
}
---

<BaseLayout title="النماذج العالمية" description="دليل شامل لأهم وأحدث نماذج الذكاء الاصطناعي الرائدة عالمياً مع مواصفاتها ونقاط قوتها وتقييماتها المرجعية">
  <div class="max-w-7xl mx-auto px-4 py-12">
    <!-- Header -->
    <div class="mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">
        أقوى نماذج <span class="gradient-text">الذكاء الاصطناعي (أبريل 2026)</span>
      </h1>
      <p class="text-gray-400 text-lg max-w-2xl">
        استعرض قائمة أقوى النماذج الصينية والعالمية التي تتصدر المؤشرات حالياً، اضغط على النموذج لقراءة التحليل التقييمي المفصل له.
      </p>
    </div>

    <!-- ===== القسم 1: النماذج اللغوية والمتعددة الوسائط ===== -->
