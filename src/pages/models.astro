const imageModels = [
  { name: 'GPT Image 1.5', company: 'OpenAI', description: 'أفضل نموذج حالياً في الالتزام بالوصف وإدراج النصوص بكفاءة.', strengths: ['نصوص متقنة', 'امتثال قوي', 'متوفر בـ GPT+', 'متعدد'], type: 'صور', slug: 'gpt-image-1-5' },
  { name: 'Gemini 3 Pro Image', company: 'Google', description: 'سيد الواقعية الفائقة (Photorealism) المعروف سابقاً בـ Nano Banana Pro.', strengths: ['وجوه واقعية', 'طبيعة', 'تكامل جوجل'], type: 'صور', slug: 'gemini-3-pro-image' },
  { name: 'FLUX.2 Pro', company: 'Black Forest Labs', description: 'أعلى جودة فنية وتفاصيل دقيقة مع سرعة توليد هائلة.', strengths: ['تشريح دقيق', 'سرعة البناء', 'أطراف سليمة'], type: 'صور', slug: 'flux-2-pro' },
  { name: 'Midjourney v8', company: 'Midjourney', description: 'الأفضل بلا منازع في الإبداع الفني (Artistic Visuals).', strengths: ['أسلوب فني مذهل', 'إضاءة إبداعية', 'تناسق الألوان'], type: 'صور', slug: 'midjourney-v8', rating: 'الأول إبداعياً' },
  { name: 'Seedream 5.0 (2.0)', company: 'ByteDance', description: 'النموذج الصيني القوي للتنوع البصري والاستخدام التجاري والإعلاني.', strengths: ['إعلانات وتجارة', 'تنوع الثقافات', 'جسم كامل'], type: 'صور', slug: 'seedream-5-0' }
