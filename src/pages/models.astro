---
import BaseLayout from '../layouts/BaseLayout.astro';
import ModelCard from '../components/ModelCard.astro';

const models = [
  {
    name: 'GPT-5.4',
    company: 'OpenAI',
    description: 'أحدث نموذج رائد، يدمج التفكير البرمجي المعقد والوكلاء الذاتيين (Agentic Workflows).',
    strengths: ['تفكير منطقي', 'وكيل ذاتي', 'متعدد الوسائط', 'سريع جداً'],
    type: 'متعدد',
    releaseDate: 'مارس 2026',
  },
  {
    name: 'Claude Opus 4.6',
    company: 'Anthropic',
    description: 'النموذج الأذكى عالمياً في كتابة الكود والتحليل المتقدم، يتفوق في المهام المعقدة.',
    strengths: ['برمجة متقدمة', 'أمان عالي', 'تحليل عبقري', 'سياق كبير'],
    type: 'لغوي',
    releaseDate: 'فبراير 2026',
  },
  {
    name: 'Gemini 3.1 Pro',
    company: 'Google DeepMind',
    description: 'أداء هائل مع نافذة سياق تفوق 2 مليون رمز، وتكامل عميق مع نظام جوجل.',
    strengths: ['سياق ضخم', 'تكامل جوجل', 'بحث حي', 'فيديو وصوت'],
    type: 'متعدد',
    releaseDate: '2026',
  },
  {
    name: 'Grok 4',
    company: 'xAI',
    description: 'الأسرع في معالجة البيانات الحية بفضل الوصول لتويتر (X)، مع قدرات خالية من الرقابة.',
    strengths: ['بيانات حية', 'بدون قيود', 'تفكير سريع', 'مفتوح نسبياً'],
    type: 'لغوي',
    releaseDate: '2026',
  },
  {
    name: 'DeepSeek-V3.2',
    company: 'DeepSeek',
    description: 'أفضل بديل مفتوح المصدر حالياً، في انتظار إطلاق الإصدار V4 المرتقب.',
    strengths: ['مفتوح المصدر', 'تكلفة منخفضة', 'برمجة مميزة', 'كفاءة عالية'],
    type: 'لغوي',
    releaseDate: 'ديسمبر 2025',
  },
  {
    name: 'Claude Sonnet 4.6',
    company: 'Anthropic',
    description: 'الموازنة المثالية بين السرعة والأداء العالي في المهام اليومية والبرمجة السريعة.',
    strengths: ['سريع وذكي', 'تسعير ممتاز', 'موثوق', 'تحليل قوي'],
    type: 'لغوي',
    releaseDate: 'فبراير 2026',
  },
  {
    name: 'Llama 4',
    company: 'Meta',
    description: 'الجيل الرابع الأقوى من نماذج لاما، يمكنه العمل محلياً على سيرفرات الشركات.',
    strengths: ['مجاني للشركات', 'بيئة محلية', 'دعم عالمي', 'قابل للتعديل'],
    type: 'لغوي',
    releaseDate: '2026',
  },
  {
    name: 'Midjourney v7',
    company: 'Midjourney',
    description: 'رائد توليد الصور بالذكاء الاصطناعي، يتميز بتناسق المشاهد والنصوص في الصور.',
    strengths: ['صور واقعية', 'أسلوب فني', 'نصوص دقيقة', 'إضاءة إبداعية'],
    type: 'صور',
    releaseDate: '2026',
  },
  {
    name: 'Sora 2',
    company: 'OpenAI',
    description: 'أقوى نموذج لتوليد مشاهد فيديو حية وطويلة بجودة سينمائية وفيزياء واقعية.',
    strengths: ['جودة سينمائية', 'دقة فيزيائية', 'عالي الوضوح', 'مؤثرات متقدمة'],
    type: 'فيديو',
    releaseDate: '2026',
  },
  {
    name: 'GPT-5.4 mini',
    company: 'OpenAI',
    description: 'نسخة اقتصادية موفرة وسريعة جداً للمهام البسيطة والتي تتطلب سرعة استجابة هائلة.',
    strengths: ['استجابة لحظية', 'رخيص جداً', 'للمهام السريعة', 'تكامل API'],
    type: 'لغوي',
    releaseDate: 'مارس 2026',
  },
];
---

<BaseLayout title="النماذج" description="دليل شامل لأهم نماذج الذكاء الاصطناعي مع مواصفاتها ونقاط قوتها">
  <div class="max-w-7xl mx-auto px-4 py-12">
    <!-- Header -->
    <div class="mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">
        نماذج <span class="gradient-text">الذكاء الاصطناعي</span>
      </h1>
      <p class="text-gray-400 text-lg max-w-2xl">
        استعرض أهم وأقوى نماذج AI في السوق مع تحليل مفصل لنقاط القوة والاستخدامات
      </p>
    </div>

    <!-- Models Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
      {models.map(model => (
        <ModelCard {...model} />
      ))}
    </div>

    <!-- Comparison Table -->
    <section>
      <h2 class="section-title flex items-center gap-3 mb-8">
        <span class="w-8 h-8 rounded-lg bg-neon-blue/10 flex items-center justify-center">
          <svg class="w-4 h-4 text-neon-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
          </svg>
        </span>
        جدول المقارنة
      </h2>
      <div class="glass-card overflow-hidden overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-dark-500/30">
              <th class="text-right p-4 text-white font-semibold">النموذج</th>
              <th class="text-right p-4 text-white font-semibold">الشركة</th>
              <th class="text-right p-4 text-white font-semibold">النوع</th>
              <th class="text-right p-4 text-white font-semibold">المميزات الرئيسية</th>
            </tr>
          </thead>
          <tbody>
            {models.map((model, i) => (
              <tr class:list={['border-b border-dark-500/20', i % 2 === 0 ? 'bg-dark-700/20' : '']}>
                <td class="p-4 text-neon-blue font-medium">{model.name}</td>
                <td class="p-4 text-gray-400">{model.company}</td>
                <td class="p-4"><span class="tag text-xs">{model.type}</span></td>
                <td class="p-4 text-gray-400">{model.strengths.slice(0, 2).join('، ')}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  </div>
</BaseLayout>
