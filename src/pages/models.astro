const videoModels = [
  { name: 'Veo 3.1', company: 'Google', description: 'النموذج الأول للواقعية ومزامنة الصوت الأصلية والتحكم الإخراجي.', strengths: ['صوت أصيل', 'فيزياء تصويرية', 'تحكم متقدم'], type: 'فيديو', slug: 'veo-3-1' },
  { name: 'Sora 2 Pro', company: 'OpenAI', description: 'الأقوى في الفيزياء وحركة العناصر والمشاهد السينمائية المتصلة.', strengths: ['جودة 4K', 'فيزياء سائلة', 'مدة طويلة'], type: 'فيديو', slug: 'sora-2-pro' },
  { name: 'Kling 3.0', company: 'Kuaishou', description: 'حركة بشرية دقيقة جداً مع ميزة تعدد اللقطات وسعر مناسب.', strengths: ['حركة بشرية سلسة', 'تعدد زوايا', 'اقتصادي'], type: 'فيديو', slug: 'kling-3-0' },
  { name: 'Runway Gen-4.5', company: 'RunwayML', description: 'الخيار الاحترافي لصناع الأفلام للتحكم بأدوات المونتاج والفرشاة.', strengths: ['أدوات إخراجية', 'حركة سائلة', 'تحكم بالكاميرا'], type: 'فيديو', slug: 'runway-gen-4-5' },
  { name: 'Seedance 2.0', company: 'ByteDance', description: 'متفوق في ثبات الشخصيات وتأثيرات منصة تيك توك الديناميكية.', strengths: ['ثبات شخصيات', 'مؤثرات قوية', 'إنتاج سريع'], type: 'فيديو', slug: 'seedance-2-0' }
];

const agentTools = [
  { name: 'OpenClaw', company: 'AI Devs', description: 'أداة الوكلاء الذاتيين المفتوحة والممتازة في مهام متعددة.', strengths: ['وكيل ذاتي', 'مرونة عالية', 'مفتوح'], type: 'متعدد', slug: 'openclaw' },
  { name: 'Kilo Code', company: 'Kilo', description: 'المساعد البرمجي الذي يبسط تعقيدات الأكواد بشكل سحري.', strengths: ['شرح الكود', 'بناء سريع', 'مفيد للمبتدئين'], type: 'متعدد', slug: 'kilo-code' },
  { name: 'Claude Code', company: 'Anthropic', description: 'واجهة سطر الأوامر (CLI) الخاصة بكلود لهندسة المشاريع فوريا.', strengths: ['CLI قوي', 'تكامل محلي', 'فهم الملفات'], type: 'لغوي', slug: 'claude-code' },
  { name: 'Cline', company: 'Cline HQ', description: 'مهندس الـ Astro الأول والمطور الذاتي الأقوى في محرر VSCode.', strengths: ['بناء تطبيقات', 'مراقبة أوامر', 'تحكم تلقائي'], type: 'متعدد', slug: 'cline' },
  { name: 'Descript', company: 'Descript', description: 'أداة تغيير قواعد تحرير الفيديو والصوت باستخدام النص فقط.', strengths: ['تعديل كنص', 'دبلجة صوتية', 'بودكاست'], type: 'متعدد', slug: 'descript' },
  { name: 'Hermes Agent', company: 'Nous Research', description: 'بناء وتخصيص تدفقات العمل الموثوقة مع أفضل نماذج הـ Agentic.', strengths: ['قرارات مستقلة', 'مهام الويب', 'تحليل'], type: 'متعدد', slug: 'hermes-agent' },
  { name: 'Janitor AI', company: 'Janitor', description: 'أكبر منصة لمحاكاة الشخصيات والتفاعل الترفيهي الغامر.', strengths: ['شخصيات مخصصة', 'حرية تامة', 'لعب الأدوار'], type: 'متعدد', slug: 'janitor-ai' },
  { name: 'ISEKAI ZERO', company: 'Games HQ', description: 'التجربة المستقبلية المعززة للذكاء الاصطناعي في بيئة الألعاب.', strengths: ['عوالم افتراضية', 'شخصيات ذكية', 'تفاعل آلي'], type: 'متعدد', slug: 'isekai-zero' },
  { name: 'Roo Code', company: 'Roo', description: 'بديل سريع لإنتاج الأكواد وبناء النماذج الأولية على المتصفح.', strengths: ['النماذج الأولية', 'بساطة', 'تصدير سريع'], type: 'لغوي', slug: 'roo-code' },
  { name: 'Lemonade', company: 'Marketing AI', description: 'منصة صناعة المحتوى الإعلاني والتسويقي الأولى لمحتوى السوشيال.', strengths: ['إدارة حملات', 'نسخ إعلانية', 'بوستات'], type: 'متعدد', slug: 'lemonade' },
  { name: 'Cursor', company: 'Cursor', description: 'محرر الأكواد المعزز بالذكاء الاصطناعي والذي يهدد عرش VS Code.', strengths: ['تعديلات ثنائية', 'سياق المشروع', 'سريع جداً'], type: 'متعدد', slug: 'cursor' },
  { name: 'Perplexity AI', company: 'Perplexity', description: 'محرك بحث متطور يجيب على تساؤلاتك مدعماً بالمصادر والمراجع.', strengths: ['بحث عميق', 'اقتباسات دقيقة', 'برو بحث'], type: 'متعدد', slug: 'perplexity-ai' },
  { name: 'ElevenLabs', company: 'ElevenLabs', description: 'التوليد الصوتي الأكثر واقعية وإنسانية في العالم بجميع اللهجات.', strengths: ['صوت طبيعي', 'دبلجة بضغطة', 'استنساخ أصوات'], type: 'صوت', slug: 'elevenlabs' },
  { name: 'Zapier AI', company: 'Zapier', description: 'تدير جميع عملياتك وتربط تطبيقاتك المختلفة بذكاء أوتوماتيكي.', strengths: ['أتمتة الشركات', 'ربط التطبيقات', 'تدفق سلس'], type: 'متعدد', slug: 'zapier-ai' },
