---
import BaseLayout from '../layouts/BaseLayout.astro';
import ModelCard from '../components/ModelCard.astro';

const languageModels = [
  { name: 'GPT-5.4', company: 'OpenAI', description: 'أحدث نموذج يدمج التفكير المنطقي الطويل والوكلاء الذاتيين.', strengths: ['تفكير منطقي', 'وكيل ذاتي', 'متعدد الوسائط'], type: 'متعدد', slug: 'gpt-5-4', rating: '1350 Elo' },
  { name: 'Claude Opus 4.6', company: 'Anthropic', description: 'ملك البرمجة المعقدة والتحليل العميق للبيانات والأرقام.', strengths: ['برمجة متقدمة', 'أمان عالي', 'طول السياق'], type: 'لغوي', slug: 'claude-opus-4-6', rating: '1340 Elo' },
  { name: 'Gemini 3.1 Pro', company: 'Google', description: 'سياق ضخم يفوق 2 مليون رمز وتكامل گوگل العميق.', strengths: ['سياق 2M', 'بحث حي', 'תكامل بيئي'], type: 'متعدد', slug: 'gemini-3-1-pro', rating: '1335 Elo' },
  { name: 'Grok 4.20', company: 'xAI', description: 'سريع جداً في معالجة البيانات الحية بفضل ربطه المباشر بتويتر.', strengths: ['بيانات حية', 'بدون قيود', 'حس الفكاهة'], type: 'لغوي', slug: 'grok-4-20-multi-agent-xai', rating: '1290 Elo' },
  { name: 'Qwen 3.6 Plus', company: 'Alibaba Cloud', description: 'النموذج الصيني المذهل الذي يُنافس أقوى النماذج الغربية بامتياز.', strengths: ['رياضيات', 'مفتوح المصدر', 'متعدد اللغات'], type: 'لغوي', slug: 'qwen-3-6-plus', rating: '1330 Elo' },
  { name: 'MiniMax M2.7', company: 'MiniMax', description: 'يتصدر التقييمات كنموذج ذو شخصية تفاعلية لتطبيقات الترفيه.', strengths: ['شخصيات مخصصة', 'صوتيات', 'تفاعل عالي'], type: 'لغوي', slug: 'minimax-m2-7', rating: '1250 Elo' },
  { name: 'MiMo-V2-Pro', company: 'Xiaomi', description: 'أقوى نموذج مدمج للأجهزة المحمولة والهواتف الذكية.', strengths: ['خفيف وسريع', 'تطبيقات الهاتف', 'آمن'], type: 'متعدد', slug: 'mimo-v2-pro-xiaomi' },
  { name: 'DeepSeek V3.2', company: 'DeepSeek', description: 'الأفضل في الفاعلية وتكلفة التشغيل، خيار المطورين الاقتصادي الأقوى.', strengths: ['تكلفة منخفضة', 'أداء برمجيات', 'سرعة'], type: 'لغوي', slug: 'deepseek-v3-2', rating: '1320 Elo' },
  { name: 'Llama 4 Maverick', company: 'Meta', description: 'ثورة ميتا المنتظرة في عالم المصادر المفتوحة بحجم ضخم.', strengths: ['مجاني', 'آمن للشركات', 'استضافة ذاتية'], type: 'لغوي', slug: 'llama-4-maverick' },
  { name: 'Claude Sonnet 4.6', company: 'Anthropic', description: 'المزيج المثالي بين السرعة الفائقة والذكاء التنافسي اليومي.', strengths: ['سرعة فائقة', 'سعر ممتاز', 'كود قوي'], type: 'لغوي', slug: 'claude-sonnet-4-6' },
  { name: 'GLM 5 / Turbo', company: 'Zhipu AI', description: 'نموذج صيني متقدم جداً يبرز في الأسواق الآسيوية للغة والموثوقية.', strengths: ['السوق الآسيوي', 'رؤية الكمبيوتر'], type: 'لغوي', slug: 'glm-5' },
  { name: 'Step 3.5 Flash', company: 'StepFun', description: 'نموذج ذو سرعة مهولة للمهام المتعددة والاستجابات اللحظية.', strengths: ['سريع جداً', 'اقتصادي', 'لوحات تحكم'], type: 'لغوي', slug: 'step-3-5-flash' },
  { name: 'Kimi K2.5', company: 'Moonshot', description: 'السيد المُطلق في قراءة الملايين من الرموز (Long Context).', strengths: ['مستندات عملاقة', 'ذاكرة كبيرة', 'تحليل كتب'], type: 'لغوي', slug: 'kimi-k2-5' }
