---

<BaseLayout title="دليل النماذج والأدوات" description="المرجع العربي الشامل لأقوى النماذج اللغوية، البصرية، الفيديو، وأدوات الوكلاء الذاتيين.">
  <div class="max-w-7xl mx-auto px-4 py-12">
    <!-- Header -->
    <div class="mb-16 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-6">
        الدليل الشامل للـ <span class="gradient-text">الرياضة العقلية الجديدة (AI)</span>
      </h1>
      <p class="text-gray-400 text-lg max-w-3xl mx-auto">
        استكشف المئات من النماذج والأدوات الأقوى عالمياً. تم تصنيفها بدقة لتشمل معالجة اللغات الطبيعية، توليد الصور والفيديو الخيالية، ووكلاء الأتمتة البرمجية. 
      </p>
    </div>

    <!-- Section 1: Language Models -->
    <section class="mb-20">
      <div class="flex items-center gap-4 mb-8 pb-4 border-b border-dark-600/50">
        <span class="w-10 h-10 rounded-xl bg-neon-blue/15 flex items-center justify-center">
          <svg class="w-5 h-5 text-neon-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
          </svg>
        </span>
        <h2 class="text-3xl font-bold text-white">النماذج اللغوية (LLMs)</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {languageModels.map((model) => (
          <ModelCard {...model} />
        ))}
      </div>
    </section>

    <!-- Section 2: Image Models -->
    <section class="mb-20">
      <div class="flex items-center gap-4 mb-8 pb-4 border-b border-dark-600/50">
        <span class="w-10 h-10 rounded-xl bg-pink-500/15 flex items-center justify-center">
          <svg class="w-5 h-5 text-pink-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </span>
        <h2 class="text-3xl font-bold text-white">نماذج إنتاج الصور</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {imageModels.map((model) => (
          <ModelCard {...model} />
        ))}
      </div>
    </section>

    <!-- Section 3: Video Models -->
    <section class="mb-20">
      <div class="flex items-center gap-4 mb-8 pb-4 border-b border-dark-600/50">
        <span class="w-10 h-10 rounded-xl bg-emerald-500/15 flex items-center justify-center">
          <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
          </svg>
        </span>
        <h2 class="text-3xl font-bold text-white">نماذج إنتاج الفيديو</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {videoModels.map((model) => (
          <ModelCard {...model} />
        ))}
      </div>
    </section>

    <!-- Section 4: AI Agents & Tools -->
    <section class="mb-20">
      <div class="flex items-center gap-4 mb-8 pb-4 border-b border-dark-600/50">
        <span class="w-10 h-10 rounded-xl bg-purple-500/15 flex items-center justify-center">
          <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </span>
        <h2 class="text-3xl font-bold text-white">وكلاء الـ AI وأقوى الأدوات</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {agentTools.map((model) => (
          <ModelCard {...model} />
        ))}
      </div>
    </section>

  </div>
</BaseLayout>
