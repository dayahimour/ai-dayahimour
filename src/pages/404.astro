---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found" lang="en" noindex={true}>
  <div class="max-w-2xl mx-auto px-4 py-32 text-center">
    <div class="text-8xl font-black gradient-text mb-6">404</div>
    <h1 class="text-3xl font-bold text-white mb-4">Page Not Found</h1>
    <p class="text-gray-400 text-lg mb-4">Sorry, the page you're looking for doesn't exist or has been moved.</p>
    <p class="text-gray-500 text-lg mb-8">عذراً، الصفحة التي تبحث عنها غير موجودة.</p>
    <div class="flex items-center justify-center gap-4">
      <a href="/ar/" class="btn-primary">الرئيسية (عربي)</a>
      <a href="/en/" class="btn-secondary">Home (English)</a>
    </div>
  </div>
</BaseLayout>
