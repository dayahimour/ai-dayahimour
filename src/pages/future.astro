---
return Astro.redirect('/ar/future/', 301);
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const futurePosts = (await getCollection('blog'))
  .filter(post => post.data.category === 'مستقبل' && !post.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout title="المستقبل" description="تنبؤات ورؤى حصرية عن مستقبل الذكاء الاصطناعي وتأثيره على العالم">
  <div class="max-w-7xl mx-auto px-4 py-12">
    <!-- Header -->
    <div class="mb-16 text-center max-w-3xl mx-auto">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-pink-500/10 border border-pink-500/20 mb-6">
        <span class="w-2 h-2 rounded-full bg-pink-400 animate-pulse"></span>
        <span class="text-sm text-pink-400 font-medium">المستقبل</span>
      </div>
      <h1 class="text-4xl md:text-6xl font-bold text-white mb-6">
        ماذا يحمل <span class="gradient-text">المستقبل</span>؟
      </h1>
      <p class="text-gray-400 text-lg leading-relaxed">
        تنبؤات مبنية على التحليل والبيانات عن مستقبل الذكاء الاصطناعي وتأثيره على حياتنا وأعمالنا ومجتمعاتنا
      </p>
    </div>

    <!-- Timeline Visual -->
    <div class="relative mb-16">
      <div class="absolute left-1/2 -translate-x-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-neon-blue via-neon-green to-transparent hidden md:block"></div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="glass-card p-6 text-center">
          <div class="w-fit px-4 h-10 rounded-full bg-neon-blue/10 border border-neon-blue/30 inline-flex items-center justify-center mx-auto mb-4">
            <span class="text-neon-blue font-bold text-sm" dir="ltr" style="white-space: nowrap;">2026 - 2030</span>
          </div>
          <h3 class="text-white font-semibold mb-2">الوكلاء المستقلون</h3>
          <p class="text-sm text-gray-400">وكلاء AI ينجزون مهام متعددة الخطوات — أتمتة 30-70% من المهام المكتبية</p>
        </div>
        <div class="glass-card p-6 text-center">
          <div class="w-fit px-4 h-10 rounded-full bg-neon-green/10 border border-neon-green/30 inline-flex items-center justify-center mx-auto mb-4">
            <span class="text-neon-green font-bold text-sm" dir="ltr" style="white-space: nowrap;">2030 - 2035</span>
          </div>
          <h3 class="text-white font-semibold mb-2">إعادة هيكلة سوق العمل</h3>
          <p class="text-sm text-gray-400">300 مليون وظيفة معرضة للأتمتة — تعاون بشري-ذكاء اصطناعي</p>
        </div>
        <div class="glass-card p-6 text-center">
          <div class="w-fit px-4 h-10 rounded-full bg-purple-500/10 border border-purple-500/30 inline-flex items-center justify-center mx-auto mb-4">
            <span class="text-purple-400 font-bold text-sm" dir="ltr" style="white-space: nowrap;">2035 - 2040</span>
          </div>
          <h3 class="text-white font-semibold mb-2">ثورة الطب والـ AGI</h3>
          <p class="text-sm text-gray-400">أدوية مصممة بالذكاء الاصطناعي — تساؤل الذكاء العام الاصطناعي</p>
        </div>
      </div>
    </div>

    <!-- Future Articles -->
    {futurePosts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {futurePosts.map(post => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            category={post.data.category}
            slug={post.slug}
            image={post.data.image}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-20">
        <p class="text-gray-400 text-lg">مقالات المستقبل قادمة قريباً...</p>
      </div>
    )}
  </div>
</BaseLayout>
