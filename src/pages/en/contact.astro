---
import BaseLayout from '../../layouts/BaseLayout.astro';
const lang = 'en';
---

<BaseLayout title="Contact Us" description="Get in touch with the AI DayaHimour team" lang={lang}>
  <div class="max-w-4xl mx-auto px-4 py-16 sm:py-24">
    <div class="mb-10 text-center">
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-6">Contact <span class="gradient-text">Us</span></h1>
      <p class="text-lg text-gray-400">We are here to answer your questions and assist you with anything related to AI</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <div class="glass-card p-8 sm:p-12">
        <h2 class="text-2xl font-semibold text-white mb-6">Contact Information</h2>
        <p class="text-gray-300 mb-8 leading-relaxed">
          We would love to hear from you. If you have any suggestions, questions about our content, or if you'd like to collaborate with us, please don't hesitate to reach out.
        </p>
        
        <div class="space-y-6">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-lg bg-neon-blue/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-neon-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-gray-400">Email Address</p>
              <a href="mailto:dayahimour@gmail.com" class="text-white hover:text-neon-blue transition-colors font-medium">dayahimour@gmail.com</a>
            </div>
          </div>
          
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-lg bg-white flex items-center justify-center p-1.5 flex-shrink-0 shadow-sm ring-1 ring-white/10">
              <img src="/icons/whatsapp-logo.svg" alt="WhatsApp" class="w-full h-full object-contain" loading="lazy" />
            </div>
            <div>
              <p class="text-sm text-gray-400">WhatsApp / Telegram</p>
              <a href="https://wa.me/213540868770" target="_blank" rel="noopener noreferrer" class="text-white hover:text-green-500 transition-colors font-medium">0540 86 87 70</a>
            </div>
          </div>
          
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-lg bg-neon-green/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-neon-green" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-gray-400">X (Twitter)</p>
              <a href="https://x.com/DayaHimour" target="_blank" rel="noopener noreferrer" class="text-white hover:text-neon-green transition-colors font-medium">@DayaHimour</a>
            </div>
          </div>
          
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-lg bg-purple-500/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-purple-400" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-gray-400">GitHub</p>
              <a href="https://github.com/dayahimour" target="_blank" rel="noopener noreferrer" class="text-white hover:text-purple-400 transition-colors font-medium">dayahimour</a>
            </div>
          </div>
        </div>
      </div>
      
      <div class="glass-card p-8 sm:p-12">
        <h2 class="text-2xl font-semibold text-white mb-6">Send a Message</h2>
        <form id="contact-form" class="space-y-4" action="https://formsubmit.co/ajax/10817d577670d2ceb6e2ba48f01d08cb" method="POST">
          <input type="hidden" name="_subject" value="New message from AI DayaHimour" />
          <input type="hidden" name="_template" value="table" />
          <input type="hidden" name="_captcha" value="false" />
          <input type="text" name="_honey" style="display:none" />
          <div>
            <label for="name" class="block text-sm font-medium text-gray-400 mb-1">Full Name</label>
            <input type="text" id="name" name="name" required class="w-full bg-dark-600 border border-dark-500/50 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-neon-blue/50" placeholder="Type your name here">
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-gray-400 mb-1">Email Address</label>
            <input type="email" id="email" name="email" required class="w-full bg-dark-600 border border-dark-500/50 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-neon-blue/50" placeholder="your@email.com">
          </div>
          <div>
            <label for="subject" class="block text-sm font-medium text-gray-400 mb-1">Subject</label>
            <input type="text" id="subject" name="subject" required class="w-full bg-dark-600 border border-dark-500/50 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-neon-blue/50" placeholder="Message subject">
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-gray-400 mb-1">Message</label>
            <textarea id="message" name="message" rows="4" required class="w-full bg-dark-600 border border-dark-500/50 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-neon-blue/50 resize-none" placeholder="How can we help you?"></textarea>
          </div>
          <button id="contact-submit" type="submit" class="btn-primary w-full py-3 mt-2">Send Message</button>
          <p id="contact-success" class="hidden text-sm text-center p-3 rounded-lg bg-neon-green/10 border border-neon-green/30 text-neon-green">
            ✓ Your message has been sent successfully! We'll reply as soon as possible.
          </p>
          <p id="contact-error" class="hidden text-sm text-center p-3 rounded-lg bg-red-500/10 border border-red-500/30 text-red-400">
            ✗ Something went wrong. Please try again or email us directly.
          </p>
        </form>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement | null;
  const successMsg = document.getElementById('contact-success');
  const errorMsg = document.getElementById('contact-error');

  let lastSubmitTime = 0;

  if (form && submitBtn) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Rate limiting: prevent spam (10 second cooldown)
      const now = Date.now();
      if (now - lastSubmitTime < 10000) {
        errorMsg!.textContent = 'Please wait 10 seconds before sending another message.';
        errorMsg?.classList.remove('hidden');
        return;
      }

      successMsg?.classList.add('hidden');
      errorMsg?.classList.add('hidden');
      const originalText = submitBtn.textContent;
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';

      try {
        const formData = new FormData(form);
        const response = await fetch(form.action, {
          method: 'POST',
          body: formData,
          headers: { 'Accept': 'application/json' },
        });
        if (response.ok) {
          form.reset();
          lastSubmitTime = Date.now();
          successMsg?.classList.remove('hidden');
        } else {
          errorMsg?.classList.remove('hidden');
        }
      } catch {
        errorMsg?.classList.remove('hidden');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
      }
    });
  }
</script>
