---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ModelCard from '../../components/ModelCard.astro';

const lang = 'en';

const languageModels = [
  { name: 'GPT-5.4', company: 'OpenAI', description: 'OpenAI\'s most advanced model, combining deep reasoning and autonomous agents for unprecedented performance.', strengths: ['10x Reasoning', 'Agentic', 'Multimodal'], type: 'Multimodal', releaseDate: 'March 2026', slug: 'gpt-5-4', logo: '/icons/openai.svg', benchmarks: { aime: 100.0, gpqa: 92.0, swe: 74.9 } },
  { name: 'Claude Opus 4.6', company: 'Anthropic', description: 'The world\'s smartest model for code and advanced analysis, dominating complex programming.', strengths: ['Advanced Coding', 'Top Safety', 'Brilliant Analysis'], type: 'Language', releaseDate: 'February 2026', slug: 'claude-opus-4-6', logo: '/icons/claude-color.svg', benchmarks: { aime: 99.8, gpqa: 91.3, swe: 80.8 } },
  { name: 'Claude Sonnet 4.6', company: 'Anthropic', description: 'Anthropic\'s fast and cost-efficient model, ideal for daily tasks and rapid coding.', strengths: ['Ultra Fast', 'Low Cost', 'Excellent Performance'], type: 'Language', releaseDate: 'March 2026', slug: 'claude-sonnet-4-6', logo: '/icons/claude-color.svg', benchmarks: { aime: 83.0, gpqa: 89.9, swe: 79.6 } },
  { name: 'Gemini 3.1 Pro', company: 'Google', description: 'Google\'s flagship model excelling in scientific reasoning and long context processing.', strengths: ['Scientific Reasoning', '1M Token Context', 'Cost Efficient'], type: 'Multimodal', releaseDate: 'February 2026', slug: 'gemini-3-1-pro', logo: '/icons/gemini-color.svg', benchmarks: { aime: 97.0, gpqa: 94.1, swe: 80.6 } },
  { name: 'Qwen 3.6 Plus', company: 'Alibaba Cloud', description: 'Powerful Chinese model rivaling top Western models with strong logical reasoning.', strengths: ['Math & Reasoning', 'Open Source', 'Multilingual'], type: 'Language', releaseDate: 'April 2026', slug: 'qwen-3-6-plus', logo: '/icons/qwen-color.svg', benchmarks: { aime: 94.1, gpqa: 88.4, swe: 73.4 } },
  { name: 'DeepSeek-V3.2', company: 'DeepSeek', description: 'Best-in-class efficiency and cost, setting a new standard for fast coding models.', strengths: ['Code & Programming', 'Low Cost', 'Blazing Fast'], type: 'Language', releaseDate: 'Late 2025', slug: 'deepseek-v3-2', logo: '/icons/deepseek-color.svg', benchmarks: { aime: 89.3, gpqa: 79.9, swe: 74.4 } },
  { name: 'Grok 4.20', company: 'xAI', description: 'Fastest live data processing with direct X (Twitter) server access, uncensored capabilities.', strengths: ['Real-time Data', 'Uncensored', 'Humor'], type: 'Language', releaseDate: 'March 2026', slug: 'grok-4-20-multi-agent-xai', logo: '/icons/grok.svg', benchmarks: { aime: 100.0, gpqa: 87.7, swe: 75.0 } },
  { name: 'Llama 4 Maverick', company: 'Meta', description: 'Open-source model outperforming GPT-4o in coding and math at 90% lower cost.', strengths: ['Open Source', 'Advanced Coding', 'Ultra Low Cost'], type: 'Language', releaseDate: 'April 2026', slug: 'llama-4-maverick', logo: '/icons/meta-color.svg', benchmarks: { gpqa: 73.1 } },
  { name: 'Kimi K2.5', company: 'Moonshot AI', description: 'Chinese model excelling in math and coding at 80% lower cost.', strengths: ['Advanced Math', 'Strong Coding', 'Exceptional Value'], type: 'Language', releaseDate: 'January 2026', slug: 'kimi-k2-5', logo: '/icons/kimi-color.svg', benchmarks: { aime: 96.1, gpqa: 87.6, swe: 76.8 } },
  { name: 'MiMo-V2-Pro', company: 'Xiaomi', description: 'Xiaomi\'s flagship model designed for complex agentic tasks with 1T+ parameters.', strengths: ['Smart Agents', '1M Token Context', 'Agentic Performance'], type: 'Language', releaseDate: 'March 2026', slug: 'mimo-v2-pro-xiaomi', logo: '/icons/xiaomimimo.svg', benchmarks: { aime: 96.0, gpqa: 87.0 } },
  { name: 'MiniMax M2.7', company: 'MiniMax', description: 'Chinese MoE model rivaling Claude Opus at 20x lower cost.', strengths: ['Efficient MoE', 'Smart Agents', 'Low Cost'], type: 'Language', releaseDate: 'March 2026', slug: 'minimax-m2-7', logo: '/icons/minimax-color.svg', benchmarks: { swe: 80.2 } },
  { name: 'GLM 5 Turbo', company: 'Zhipu AI', description: 'Versatile Chinese general-purpose model from Zhipu AI.', strengths: ['Versatile', 'Great Chinese Support', 'Affordable'], type: 'Language', releaseDate: 'April 2026', slug: 'glm-5', logo: '/icons/chatglm-color.svg', benchmarks: { aime: 98.0, swe: 77.8 } },
  { name: 'GLM-5.1', company: 'Zhipu AI (Z.ai)', description: '754B parameter model that works 8 hours autonomously with self-improving coding.', strengths: ['8-Hour Autonomy', 'Advanced Coding', 'MIT Open Source'], type: 'Language', releaseDate: 'March 2026', slug: 'glm-5-1-long-horizon', logo: '/icons/chatglm-color.svg', benchmarks: { swe: 76.5 } },
  { name: 'Step 3.5 Flash', company: 'StepFun', description: 'Free and fast model from StepFun for simple tasks.', strengths: ['Free', 'Ultra Fast', 'Easy to Use'], type: 'Language', releaseDate: 'April 2026', slug: 'step-3-5-flash', logo: '/icons/stepfun-color.svg', benchmarks: { aime: 97.3, swe: 74.4 } },
];

const imageModels = [
  { name: 'GPT Image 1.5', company: 'OpenAI', description: 'Best model for precise text-to-image prompt adherence and in-image text rendering.', strengths: ['Prompt Adherence', 'Accurate Text', 'ChatGPT Plus'], type: 'Image', releaseDate: 'April 2026', slug: 'gpt-image-1-5', logo: '/icons/openai.svg', benchmarks: { elo: 1264, p: 'Excellent (5/5)', r: 'Good (4/5)' } },
  { name: 'Gemini 3 Pro Image', company: 'Google', description: 'Excels in photorealism and multimodal integration within Google\'s ecosystem.', strengths: ['Photorealism', 'Google Integration', 'Smart Editing'], type: 'Image', releaseDate: 'March 2026', slug: 'gemini-3-pro-image', logo: '/icons/gemini-color.svg', benchmarks: { elo: 1252, p: 'Community Leader', r: '4K Top' } },
  { name: 'FLUX.2 Pro', company: 'Black Forest Labs', description: 'Highest artistic quality and fine details with blazing generation speed.', strengths: ['Stunning Details', 'Correct Anatomy', 'Fast Generation'], type: 'Image', releaseDate: '2026', slug: 'flux-2-pro', logo: '/icons/flux.svg', benchmarks: { elo: 1265, p: 'Fair (3/5)', r: 'Excellent (5/5)' } },
  { name: 'Midjourney v8', company: 'Midjourney', description: 'Unmatched in artistic creative style and cinematic visual aesthetics.', strengths: ['Artistic Style', 'Creative Lighting', 'Color Harmony'], type: 'Image', releaseDate: 'April 2026', slug: 'midjourney-v8', logo: '/icons/midjourney.svg', benchmarks: { elo: null, p: 'Improved', r: 'High Aesthetic' } },
  { name: 'Seedream 5.0', company: 'ByteDance', description: 'Powerful Chinese model for visual diversity and fast commercial use.', strengths: ['Commercial Use', 'Cultural Diversity', 'Nearly Free'], type: 'Image', releaseDate: 'March 2026', slug: 'seedream-5-0', logo: '/icons/bytedance-color.svg', benchmarks: { elo: 1225, p: 'CoT Reasoning', r: 'Product Leader' } },
];

const videoModels = [
  { name: 'Veo 3.1', company: 'Google', description: 'Leading model for realism, native audio sync, and cinematic control.', strengths: ['Native Audio', 'Accurate Physics', 'Cinematic Control'], type: 'Video', releaseDate: 'April 2026', slug: 'veo-3-1', logo: '/icons/google-color.svg', benchmarks: { elo: null, r: 'Lead Realism', a: 'Native Sync', c: 'High' } },
  { name: 'Sora 2 Pro', company: 'OpenAI', description: 'Strongest in realistic physics and story-driven motion at high quality with audio sync.', strengths: ['Complex Motion', '4K+ Quality', 'Scene Continuity'], type: 'Video', releaseDate: 'March 2026', slug: 'sora-2-pro', logo: '/icons/sora-color.svg', benchmarks: { elo: null, r: 'Leading Physics', a: 'Synced', c: 'Narrative' } },
  { name: 'Kling 3.0', company: 'Kuaishou', description: 'Best value for creators with smooth human motion and multi-shot support.', strengths: ['Accurate Human Motion', 'Best Value', 'Cross-Platform'], type: 'Video', releaseDate: 'February 2026', slug: 'kling-3-0', logo: '/icons/kling-color.svg', benchmarks: { elo: 1106, r: 'Native 4K 60fps', a: 'Upload Ref', c: 'Multi-shot' } },
  { name: 'Runway Gen-4.5', company: 'RunwayML', description: 'Best for professional creative control and filmmakers with advanced editing tools.', strengths: ['Director Control', 'Precise Animation', 'Editing Tools'], type: 'Video', releaseDate: 'April 2026', slug: 'runway-gen-4-5', logo: '/icons/runway.svg', benchmarks: { elo: 1247, r: 'Visual Fidelity', a: 'Not native', c: 'Editor Tools' } },
  { name: 'Seedance 2.0', company: 'ByteDance', description: 'Excels in character consistency with novel dual-branch diffusion architecture.', strengths: ['Character Consistency', 'Fast Processing', 'TikTok Effects'], type: 'Video', releaseDate: '2026', slug: 'seedance-2-0', logo: '/icons/bytedance-color.svg', benchmarks: { elo: 1269, r: 'Joint Gen Leader', a: 'Native Lip-sync', c: '@ Control' } },
];
---

<BaseLayout title="AI Models" description="Comprehensive guide to the most powerful AI models worldwide with specs, strengths, and benchmarks" lang={lang}>
  <div class="max-w-7xl mx-auto px-4 py-12">
    <div class="mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">
        Most Powerful <span class="gradient-text">AI Models (April 2026)</span>
      </h1>
      <p class="text-gray-400 text-lg max-w-2xl">
        Explore the leading AI models dominating benchmarks today. Click any model to read the full analysis.
      </p>
    </div>

    <!-- Language Models -->
    <section class="mb-20">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-2 flex items-center gap-3">
        <span class="w-10 h-10 rounded-xl bg-blue-500/10 flex items-center justify-center">
          <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" /></svg>
        </span>
        Language & Multimodal Models
      </h2>
      <p class="text-gray-500 text-sm mb-8">Chat, reasoning, and coding models — benchmarked on AIME, GPQA Diamond, SWE-bench</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-10">
        {languageModels.map(model => <ModelCard {...model} lang={lang} />)}
      </div>

      <div class="glass-card overflow-hidden overflow-x-auto" style="background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); border: 1px solid rgba(99,179,237,0.12); border-radius: 16px;">
        <div style="padding: 24px 24px 8px 24px;">
          <p style="color: #94a3b8; font-size: 13px; text-align: center; margin: 0 0 20px 0;">Language Model Benchmarks — April 2026</p>
        </div>
        <table class="w-full text-sm text-left align-middle">
          <thead>
            <tr class="border-b border-dark-500/30">
              <th class="p-4 text-white font-semibold">Model</th>
              <th class="p-4 text-white font-semibold">Company</th>
              <th class="p-4 text-center font-semibold" style="color: #60a5fa;">AIME 2025</th>
              <th class="p-4 text-center font-semibold" style="color: #a78bfa;">GPQA Diamond</th>
              <th class="p-4 text-center font-semibold" style="color: #34d399;">SWE-bench</th>
            </tr>
          </thead>
          <tbody>
            {languageModels.sort((a, b) => (b.benchmarks?.swe || 0) - (a.benchmarks?.swe || 0)).map((model, i) => (
              <tr class:list={['border-b border-dark-500/10 hover:bg-white/5 transition-colors', i % 2 === 0 ? 'bg-white/[0.02]' : '']}>
                <td class="p-4"><a href={`/en/blog/${model.slug}`} class="text-neon-blue font-medium hover:underline">{model.name}</a></td>
                <td class="p-4 text-gray-400 text-xs">{model.company}</td>
                <td class="p-4" style="min-width: 130px;">
                  <div class="flex justify-between mb-1"><span style="font-size:11px;color:#94a3b8">Math</span><span style={`font-size:12px;font-weight:700;color:${model.benchmarks.aime >= 93 ? '#60a5fa' : '#94a3b8'}`}>{model.benchmarks.aime}%</span></div>
                  <div style="background:rgba(255,255,255,0.06);border-radius:4px;height:6px;overflow:hidden"><div style={`width:${model.benchmarks.aime}%;height:100%;background:linear-gradient(90deg,#3b82f6,#60a5fa);border-radius:4px`}></div></div>
                </td>
                <td class="p-4" style="min-width: 130px;">
                  <div class="flex justify-between mb-1"><span style="font-size:11px;color:#94a3b8">Science</span><span style={`font-size:12px;font-weight:700;color:${model.benchmarks.gpqa >= 86 ? '#a78bfa' : '#94a3b8'}`}>{model.benchmarks.gpqa}%</span></div>
                  <div style="background:rgba(255,255,255,0.06);border-radius:4px;height:6px;overflow:hidden"><div style={`width:${model.benchmarks.gpqa}%;height:100%;background:linear-gradient(90deg,#7c3aed,#a78bfa);border-radius:4px`}></div></div>
                </td>
                <td class="p-4" style="min-width: 130px;">
                  <div class="flex justify-between mb-1"><span style="font-size:11px;color:#94a3b8">Code</span><span style={`font-size:12px;font-weight:700;color:${model.benchmarks.swe >= 70 ? '#34d399' : '#94a3b8'}`}>{model.benchmarks.swe}%</span></div>
                  <div style="background:rgba(255,255,255,0.06);border-radius:4px;height:6px;overflow:hidden"><div style={`width:${model.benchmarks.swe}%;height:100%;background:linear-gradient(90deg,#059669,#34d399);border-radius:4px`}></div></div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Image Models -->
    <section class="mb-20">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-2 flex items-center gap-3">
        <span class="w-10 h-10 rounded-xl bg-amber-500/10 flex items-center justify-center">
          <svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
        </span>
        Image Generation Models
      </h2>
      <p class="text-gray-500 text-sm mb-8">AI image generation — compared on ELO Score, Prompt Adherence, Realism</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-10">
        {imageModels.map(model => <ModelCard {...model} lang={lang} />)}
      </div>

      <div class="glass-card overflow-hidden overflow-x-auto" style="background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); border: 1px solid rgba(245,158,11,0.12); border-radius: 16px;">
        <div style="padding: 24px 24px 8px 24px;">
          <p style="color: #94a3b8; font-size: 13px; text-align: center; margin: 0 0 20px 0;">Image Model Ratings — Artificial Analysis April 2026</p>
        </div>
        <table class="w-full text-sm text-left align-middle">
          <thead>
            <tr class="border-b border-dark-500/30">
              <th class="p-4 text-white font-semibold">Model</th>
              <th class="p-4 text-white font-semibold">Company</th>
              <th class="p-4 text-center font-semibold" style="color: #fbbf24;">ELO</th>
              <th class="p-4 text-center font-semibold" style="color: #f97316;">Prompt</th>
              <th class="p-4 text-center font-semibold" style="color: #a78bfa;">Realism</th>
            </tr>
          </thead>
          <tbody>
            {imageModels.sort((a, b) => (b.benchmarks?.elo || 0) - (a.benchmarks?.elo || 0)).map((model, i) => (
              <tr class:list={['border-b border-dark-500/10 hover:bg-white/5', i % 2 === 0 ? 'bg-white/[0.02]' : '']}>
                <td class="p-4"><a href={`/en/blog/${model.slug}`} class="text-amber-400 font-medium hover:underline">{model.name}</a></td>
                <td class="p-4 text-gray-400 text-xs">{model.company}</td>
                <td class="p-4 text-center"><span style="color:#fbbf24;font-weight:700">{model.benchmarks.elo || 'N/A'}</span></td>
                <td class="p-4 text-center"><span style="color:#f97316;font-size:13px;font-weight:600">{model.benchmarks.p || 'N/A'}</span></td>
                <td class="p-4 text-center"><span style="color:#a78bfa;font-size:13px;font-weight:600">{model.benchmarks.r || 'N/A'}</span></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Video Models -->
    <section class="mb-16">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-2 flex items-center gap-3">
        <span class="w-10 h-10 rounded-xl bg-pink-500/10 flex items-center justify-center">
          <svg class="w-5 h-5 text-pink-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
        </span>
        Video Generation Models
      </h2>
      <p class="text-gray-500 text-sm mb-8">Cinematic AI video generation — compared on Realism, Audio, Cinematic Control</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-10">
        {videoModels.map(model => <ModelCard {...model} lang={lang} />)}
      </div>

      <div class="glass-card overflow-hidden overflow-x-auto" style="background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); border: 1px solid rgba(236,72,153,0.12); border-radius: 16px;">
        <div style="padding: 24px 24px 8px 24px;">
          <p style="color: #94a3b8; font-size: 13px; text-align: center; margin: 0 0 20px 0;">Video Model Ratings — Video Arena April 2026</p>
        </div>
        <table class="w-full text-sm text-left align-middle">
          <thead>
            <tr class="border-b border-dark-500/30">
              <th class="p-4 text-white font-semibold">Model</th>
              <th class="p-4 text-white font-semibold">Company</th>
              <th class="p-4 text-center font-semibold" style="color: #f472b6;">Realism</th>
              <th class="p-4 text-center font-semibold" style="color: #22d3ee;">Audio</th>
              <th class="p-4 text-center font-semibold" style="color: #a78bfa;">Control</th>
            </tr>
          </thead>
          <tbody>
            {videoModels.map((model, i) => (
              <tr class:list={['border-b border-dark-500/10 hover:bg-white/5', i % 2 === 0 ? 'bg-white/[0.02]' : '']}>
                <td class="p-4"><a href={`/en/blog/${model.slug}`} class="text-pink-400 font-medium hover:underline">{model.name}</a></td>
                <td class="p-4 text-gray-400 text-xs">{model.company}</td>
                <td class="p-4 text-center"><span style="color:#f472b6;font-size:13px;font-weight:600">{model.benchmarks.r || 'N/A'}</span></td>
                <td class="p-4 text-center"><span style="color:#0891b2;font-size:12px;font-weight:600">{model.benchmarks.a || 'N/A'}</span></td>
                <td class="p-4 text-center"><span style="color:#a78bfa;font-size:13px;font-weight:600">{model.benchmarks.c || 'N/A'}</span></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  </div>
</BaseLayout>
