---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ModelCard from '../../components/ModelCard.astro';
import { languageModels, imageModels, videoModels } from '../../data/models-en';

const lang = 'en';
---

<BaseLayout title="AI Models" description="Comprehensive guide to the most powerful AI models worldwide with specs, strengths, and benchmarks" lang={lang}>
  <div class="max-w-7xl mx-auto px-4 py-12">
    <div class="mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">
        Most Powerful <span class="gradient-text">AI Models (April 2026)</span>
      </h1>
      <p class="text-gray-400 text-lg max-w-2xl">
        Explore the leading AI models dominating benchmarks today. Click any model to read the full analysis.
      </p>
    </div>

    <!-- Language Models -->
    <section class="mb-20">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-2 flex items-center gap-3">
        <span class="w-10 h-10 rounded-xl bg-blue-500/10 flex items-center justify-center">
          <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" /></svg>
        </span>
        Language & Multimodal Models
      </h2>
      <p class="text-gray-500 text-sm mb-8">Chat, reasoning, and coding models — benchmarked on AIME, GPQA Diamond, SWE-bench</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-10">
        {languageModels.map(model => <ModelCard {...model} lang={lang} />)}
      </div>

      <div class="glass-card overflow-hidden overflow-x-auto" style="background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); border: 1px solid rgba(99,179,237,0.12); border-radius: 16px;">
        <div style="padding: 24px 24px 8px 24px;">
          <p style="color: #94a3b8; font-size: 13px; text-align: center; margin: 0 0 20px 0;">Language Model Benchmarks — April 2026</p>
        </div>
        <table class="w-full text-sm text-left align-middle">
          <thead>
            <tr class="border-b border-dark-500/30">
              <th class="p-4 text-white font-semibold">Model</th>
              <th class="p-4 text-white font-semibold">Company</th>
              <th class="p-4 text-center font-semibold" style="color: #60a5fa;">AIME 2025</th>
              <th class="p-4 text-center font-semibold" style="color: #a78bfa;">GPQA Diamond</th>
              <th class="p-4 text-center font-semibold" style="color: #34d399;">SWE-bench</th>
            </tr>
          </thead>
          <tbody>
            {languageModels.sort((a, b) => (b.benchmarks?.swe || 0) - (a.benchmarks?.swe || 0)).map((model, i) => (
              <tr class:list={['border-b border-dark-500/10 hover:bg-white/5 transition-colors', i % 2 === 0 ? 'bg-white/[0.02]' : '']}>
                <td class="p-4"><a href={`/en/blog/${model.slug}/`} class="text-neon-blue font-medium hover:underline">{model.name}</a></td>
                <td class="p-4 text-gray-400 text-xs">{model.company}</td>
                <td class="p-4" style="min-width: 130px;">
                  <div class="flex justify-between mb-1"><span style="font-size:11px;color:#94a3b8">Math</span><span style={`font-size:12px;font-weight:700;color:${model.benchmarks.aime >= 93 ? '#60a5fa' : '#94a3b8'}`}>{model.benchmarks.aime}%</span></div>
                  <div style="background:rgba(255,255,255,0.06);border-radius:4px;height:6px;overflow:hidden"><div style={`width:${model.benchmarks.aime}%;height:100%;background:linear-gradient(90deg,#3b82f6,#60a5fa);border-radius:4px`}></div></div>
                </td>
                <td class="p-4" style="min-width: 130px;">
                  <div class="flex justify-between mb-1"><span style="font-size:11px;color:#94a3b8">Science</span><span style={`font-size:12px;font-weight:700;color:${model.benchmarks.gpqa >= 86 ? '#a78bfa' : '#94a3b8'}`}>{model.benchmarks.gpqa}%</span></div>
                  <div style="background:rgba(255,255,255,0.06);border-radius:4px;height:6px;overflow:hidden"><div style={`width:${model.benchmarks.gpqa}%;height:100%;background:linear-gradient(90deg,#7c3aed,#a78bfa);border-radius:4px`}></div></div>
                </td>
                <td class="p-4" style="min-width: 130px;">
                  <div class="flex justify-between mb-1"><span style="font-size:11px;color:#94a3b8">Code</span><span style={`font-size:12px;font-weight:700;color:${model.benchmarks.swe >= 70 ? '#34d399' : '#94a3b8'}`}>{model.benchmarks.swe}%</span></div>
                  <div style="background:rgba(255,255,255,0.06);border-radius:4px;height:6px;overflow:hidden"><div style={`width:${model.benchmarks.swe}%;height:100%;background:linear-gradient(90deg,#059669,#34d399);border-radius:4px`}></div></div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Image Models -->
    <section class="mb-20">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-2 flex items-center gap-3">
        <span class="w-10 h-10 rounded-xl bg-amber-500/10 flex items-center justify-center">
          <svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
        </span>
        Image Generation Models
      </h2>
      <p class="text-gray-500 text-sm mb-8">AI image generation — compared on ELO Score, Prompt Adherence, Realism</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-10">
        {imageModels.map(model => <ModelCard {...model} lang={lang} />)}
      </div>

      <div class="glass-card overflow-hidden overflow-x-auto" style="background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); border: 1px solid rgba(245,158,11,0.12); border-radius: 16px;">
        <div style="padding: 24px 24px 8px 24px;">
          <p style="color: #94a3b8; font-size: 13px; text-align: center; margin: 0 0 20px 0;">Image Model Ratings — Artificial Analysis April 2026</p>
        </div>
        <table class="w-full text-sm text-left align-middle">
          <thead>
            <tr class="border-b border-dark-500/30">
              <th class="p-4 text-white font-semibold">Model</th>
              <th class="p-4 text-white font-semibold">Company</th>
              <th class="p-4 text-center font-semibold" style="color: #fbbf24;">ELO</th>
              <th class="p-4 text-center font-semibold" style="color: #f97316;">Prompt</th>
              <th class="p-4 text-center font-semibold" style="color: #a78bfa;">Realism</th>
            </tr>
          </thead>
          <tbody>
            {imageModels.sort((a, b) => (b.benchmarks?.elo || 0) - (a.benchmarks?.elo || 0)).map((model, i) => (
              <tr class:list={['border-b border-dark-500/10 hover:bg-white/5', i % 2 === 0 ? 'bg-white/[0.02]' : '']}>
                <td class="p-4"><a href={`/en/blog/${model.slug}/`} class="text-amber-400 font-medium hover:underline">{model.name}</a></td>
                <td class="p-4 text-gray-400 text-xs">{model.company}</td>
                <td class="p-4 text-center"><span style="color:#fbbf24;font-weight:700">{model.benchmarks.elo || 'N/A'}</span></td>
                <td class="p-4 text-center"><span style="color:#f97316;font-size:13px;font-weight:600">{model.benchmarks.p || 'N/A'}</span></td>
                <td class="p-4 text-center"><span style="color:#a78bfa;font-size:13px;font-weight:600">{model.benchmarks.r || 'N/A'}</span></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Video Models -->
    <section class="mb-16">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-2 flex items-center gap-3">
        <span class="w-10 h-10 rounded-xl bg-pink-500/10 flex items-center justify-center">
          <svg class="w-5 h-5 text-pink-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
        </span>
        Video Generation Models
      </h2>
      <p class="text-gray-500 text-sm mb-8">Cinematic AI video generation — compared on Realism, Audio, Cinematic Control</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-10">
        {videoModels.map(model => <ModelCard {...model} lang={lang} />)}
      </div>

      <div class="glass-card overflow-hidden overflow-x-auto" style="background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); border: 1px solid rgba(236,72,153,0.12); border-radius: 16px;">
        <div style="padding: 24px 24px 8px 24px;">
          <p style="color: #94a3b8; font-size: 13px; text-align: center; margin: 0 0 20px 0;">Video Model Ratings — Video Arena April 2026</p>
        </div>
        <table class="w-full text-sm text-left align-middle">
          <thead>
            <tr class="border-b border-dark-500/30">
              <th class="p-4 text-white font-semibold">Model</th>
              <th class="p-4 text-white font-semibold">Company</th>
              <th class="p-4 text-center font-semibold" style="color: #f472b6;">Realism</th>
              <th class="p-4 text-center font-semibold" style="color: #22d3ee;">Audio</th>
              <th class="p-4 text-center font-semibold" style="color: #a78bfa;">Control</th>
            </tr>
          </thead>
          <tbody>
            {videoModels.map((model, i) => (
              <tr class:list={['border-b border-dark-500/10 hover:bg-white/5', i % 2 === 0 ? 'bg-white/[0.02]' : '']}>
                <td class="p-4"><a href={`/en/blog/${model.slug}/`} class="text-pink-400 font-medium hover:underline">{model.name}</a></td>
                <td class="p-4 text-gray-400 text-xs">{model.company}</td>
                <td class="p-4 text-center"><span style="color:#f472b6;font-size:13px;font-weight:600">{model.benchmarks.r || 'N/A'}</span></td>
                <td class="p-4 text-center"><span style="color:#0891b2;font-size:12px;font-weight:600">{model.benchmarks.a || 'N/A'}</span></td>
                <td class="p-4 text-center"><span style="color:#a78bfa;font-size:13px;font-weight:600">{model.benchmarks.c || 'N/A'}</span></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  </div>
</BaseLayout>
