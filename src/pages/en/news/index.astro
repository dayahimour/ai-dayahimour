---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import NewsCard from '../../../components/NewsCard.astro';
import { t } from '../../../i18n/translations';
import { getCollection } from 'astro:content';

const lang = 'en';

const NEWS_EXPIRY_DAYS_UNLINKED = 14;
const NEWS_EXPIRY_DAYS_LINKED = 60;

const now = new Date();
const cutoffUnlinked = new Date();
cutoffUnlinked.setDate(now.getDate() - NEWS_EXPIRY_DAYS_UNLINKED);
const cutoffLinked = new Date();
cutoffLinked.setDate(now.getDate() - NEWS_EXPIRY_DAYS_LINKED);

const allNews = (await getCollection('news-en'))
  .flatMap(entry => entry.data)
  .filter(item => {
    if (item.draft) return false;
    const itemDate = new Date(item.date);
    if (item.articleSlug) {
      return itemDate >= cutoffLinked;
    }
    return itemDate >= cutoffUnlinked;
  })
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const prominentNews = allNews.filter(n => n.importance === 'prominent').slice(0, 8);

const companies = [...new Set(allNews.map(n => n.company).filter(Boolean))];

// Generate JSON-LD schema for all news items on this page
const newsSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "itemListElement": allNews.map((item, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "item": {
      "@type": "NewsArticle",
      "headline": item.headline,
      "description": item.summary,
      "datePublished": item.date,
      "publisher": {
        "@type": "Organization",
        "name": item.source,
      },
      "url": item.articleSlug ? new URL(`/${lang}/blog/${item.articleSlug}/`, Astro.site).toString() : item.sourceUrl,
    }
  }))
};
---

<BaseLayout 
  title={t(lang, 'news.pageTitle')} 
  description={t(lang, 'news.subtitle')} 
  keywords={t(lang, 'news.pageKeywords')} 
  lang={lang}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(newsSchema).replace(/</g, '\\u003c')} />
  </Fragment>

  <div class="max-w-7xl mx-auto px-4 py-12">
    <!-- Header -->
    <div class="mb-10">
      <div class="flex items-center gap-3 mb-4">
        <span class="w-2.5 h-2.5 rounded-full bg-neon-green animate-pulse"></span>
        <span class="text-sm font-medium text-neon-green">Latest News</span>
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">
        {t(lang, 'news.title')} <span class="gradient-text">{t(lang, 'news.titleHighlight')}</span>
      </h1>
      <p class="text-gray-400 text-lg max-w-2xl">{t(lang, 'news.subtitle')}</p>
    </div>

    <!-- Prominent News -->
    {prominentNews.length > 0 && (
      <section class="mb-12">
        <h2 class="text-xl font-bold text-white mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-neon-blue animate-pulse"></span>
          {t(lang, 'news.sectionProminent')}
        </h2>
        <div class="columns-1 md:columns-2 lg:columns-3 gap-4 space-y-4">
          {prominentNews.map(item => (
            <div class="break-inside-avoid">
              <NewsCard
                headline={item.headline}
                summary={item.summary}
                date={item.date}
                publishedAt={item.publishedAt}
                source={item.source}
                sourceUrl={item.sourceUrl}
                articleSlug={item.articleSlug}
                company={item.company}
                importance={item.importance || 'normal'}
                lang={lang}
              />
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Filters -->
    <div class="mb-8">
      {companies.length > 0 && (
        <div class="flex flex-wrap gap-2" id="company-filter">
          <button class="company-btn px-3 py-1.5 rounded-lg text-xs font-medium transition-all border border-dark-500/20 text-gray-500 hover:text-white hover:bg-dark-600/50" data-company="All">All</button>
          {companies.map(company => (
            <button class="company-btn px-3 py-1.5 rounded-lg text-xs font-medium transition-all border border-dark-500/20 text-gray-500 hover:text-white hover:bg-dark-600/50" data-company={company}>{company}</button>
          ))}
        </div>
      )}
    </div>

    <!-- Stats bar -->
    <div class="flex items-center gap-4 mb-8 text-sm text-gray-500">
      <span class="flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
        </svg>
        {allNews.length} news items
      </span>
    </div>

    <!-- All News -->
    <h2 class="text-xl font-bold text-white mb-4 flex items-center gap-2">
      <span class="w-2 h-2 rounded-full bg-gray-400"></span>
      {t(lang, 'news.sectionAll')}
    </h2>

    <div class="columns-1 md:columns-2 lg:columns-3 gap-4 space-y-4" id="news-grid">
      {allNews.map(item => (
        <div class="news-item break-inside-avoid" data-company={item.company || ''}>
          <NewsCard
            headline={item.headline}
            summary={item.summary}
            date={item.date}
            publishedAt={item.publishedAt}
            source={item.source}
            sourceUrl={item.sourceUrl}
            articleSlug={item.articleSlug}
            company={item.company}
            importance={item.importance || 'normal'}
            lang={lang}
          />
        </div>
      ))}
    </div>

    <!-- Empty state -->
    <div id="empty-state" class="hidden text-center py-20">
      <svg class="w-16 h-16 text-dark-500 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
      </svg>
      <p class="text-gray-400 text-lg">{t(lang, 'news.noResults')}</p>
    </div>
  </div>
</BaseLayout>

<script>
  const companyBtns = document.querySelectorAll('.company-btn');
  const newsItems = document.querySelectorAll('.news-item');
  const emptyState = document.getElementById('empty-state');

  let activeCompany = 'All';

  companyBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      activeCompany = btn.getAttribute('data-company') || 'All';
      companyBtns.forEach(b => {
        b.classList.remove('bg-neon-blue/20', 'text-neon-blue', 'border-neon-blue/30');
        b.classList.add('text-gray-500');
      });
      btn.classList.add('bg-neon-blue/20', 'text-neon-blue', 'border-neon-blue/30');
      btn.classList.remove('text-gray-500');
      filterNews();
    });
  });

  companyBtns[0]?.classList.add('bg-neon-blue/20', 'text-neon-blue', 'border-neon-blue/30');
  companyBtns[0]?.classList.remove('text-gray-500');

  function filterNews() {
    let count = 0;
    newsItems.forEach(item => {
      const company = item.getAttribute('data-company') || '';
      const show = activeCompany === 'All' || company === activeCompany;
      (item as HTMLElement).style.display = show ? '' : 'none';
      if (show) count++;
    });
    if (emptyState) emptyState.classList.toggle('hidden', count > 0);
  }

  filterNews();
</script>
