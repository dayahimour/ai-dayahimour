---
import type { Lang } from '../i18n/translations';

interface Props {
  headline: string;
  summary: string;
  date: string;
  source: string;
  sourceUrl: string;
  articleSlug?: string;
  company?: string;
  lang?: Lang;
}

const { headline, summary, date, source, sourceUrl, articleSlug, company, lang = 'ar' } = Astro.props;

const dateLocale = lang === 'ar' ? 'ar-EG' : 'en-US';
const now = new Date();
const newsDate = new Date(date);
const diffMs = now.getTime() - newsDate.getTime();
const diffHours = Math.floor(diffMs / (1000 * 60 * 60));
const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));

let timeAgo: string;
if (diffHours < 1) {
  timeAgo = lang === 'ar' ? 'الآن' : 'Just now';
} else if (diffHours < 24) {
  timeAgo = lang === 'ar' ? `منذ ${diffHours} ساعة` : `${diffHours}h ago`;
} else if (diffDays < 7) {
  timeAgo = lang === 'ar' ? `منذ ${diffDays} يوم` : `${diffDays}d ago`;
} else {
  timeAgo = newsDate.toLocaleDateString(dateLocale, { month: 'short', day: 'numeric' });
}

const isNew = diffHours < 24;
const isInternal = !!articleSlug;
const href = isInternal ? `/${lang}/blog/${articleSlug}/` : sourceUrl;
---

<a
  href={href}
  target={isInternal ? '_self' : '_blank'}
  rel={isInternal ? undefined : 'noopener noreferrer'}
  class="group block"
>
  <article class:list={[
    'relative overflow-hidden rounded-xl border transition-all duration-300',
    isInternal
      ? 'bg-dark-700/40 border-neon-blue/20 hover:border-neon-blue/50 hover:shadow-lg hover:shadow-neon-blue/10'
      : 'bg-dark-700/40 border-dark-500/30 hover:border-dark-400/50 hover:shadow-lg hover:shadow-dark-500/10',
  ]}>
    <div class="p-4">
      <!-- Top row: dot + company + time -->
      <div class="flex items-center justify-between mb-3">
        <div class="flex items-center gap-2">
          <span class:list={['w-2 h-2 rounded-full shrink-0', isNew ? 'bg-neon-green animate-pulse' : 'bg-dark-400']}></span>
          {isInternal && (
            <span class="inline-flex items-center gap-1 px-2 py-0.5 text-[10px] font-semibold rounded-full bg-neon-blue/10 text-neon-blue border border-neon-blue/20">
              <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              {lang === 'ar' ? 'مقالة' : 'Article'}
            </span>
          )}
          {company && (
            <span class="text-[11px] font-medium text-gray-500 bg-dark-600/50 px-2 py-0.5 rounded-full">
              {company}
            </span>
          )}
        </div>
        <span class="text-[11px] text-gray-500 shrink-0">{timeAgo}</span>
      </div>

      <!-- Headline -->
      <h3 class="text-sm font-bold text-white mb-2 leading-tight group-hover:text-neon-blue transition-colors">
        {headline}
      </h3>

      <!-- Summary -->
      <p class="text-xs text-gray-400 leading-relaxed mb-3 line-clamp-2">
        {summary}
      </p>

      <!-- Bottom row: source + link icon -->
      <div class="flex items-center justify-between">
        <span class="text-[11px] text-gray-500 flex items-center gap-1.5">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
          </svg>
          {source}
        </span>
        {isInternal ? (
          <svg class="w-3.5 h-3.5 text-neon-blue/50 group-hover:text-neon-blue transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        ) : (
          <svg class="w-3.5 h-3.5 text-gray-600 group-hover:text-gray-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        )}
      </div>
    </div>
  </article>
</a>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
