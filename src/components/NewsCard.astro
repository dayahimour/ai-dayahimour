---
import type { Lang } from '../i18n/translations';

interface Props {
  headline: string;
  summary: string;
  date: string;
  source: string;
  sourceUrl?: string;
  articleSlug?: string;
  company?: string;
  importance?: 'prominent' | 'normal';
  lang?: Lang;
}

const { headline, summary, date, source, sourceUrl, articleSlug, company, importance = 'normal', lang = 'ar' } = Astro.props;

const dateLocale = lang === 'ar' ? 'ar-EG' : 'en-US';
const newsDate = new Date(date);
const isInternal = !!articleSlug;
const href = isInternal ? `/${lang}/blog/${articleSlug}/` : undefined;
---

{isInternal ? (
  <!-- Internal article link -->
  <a
    href={href}
    class="group block news-card"
    data-date={date}
    data-lang={lang}
  >
    <article class="relative overflow-hidden rounded-xl border transition-all duration-300 bg-dark-700/40 border-neon-blue/20 hover:border-neon-blue/50 hover:shadow-lg hover:shadow-neon-blue/10">
      <div class="p-4">
        <!-- Top row: dot + company + time -->
        <div class="flex items-center justify-between mb-3">
          <div class="flex items-center gap-2">
            <span class="news-dot w-2 h-2 rounded-full shrink-0 bg-dark-400"></span>
            <span class="inline-flex items-center gap-1 px-2 py-0.5 text-[10px] font-semibold rounded-full bg-neon-blue/10 text-neon-blue border border-neon-blue/20">
              <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              {lang === 'ar' ? 'مقالة' : 'Article'}
            </span>
            {company && (
              <span class="text-[11px] font-medium text-gray-500 bg-dark-600/50 px-2 py-0.5 rounded-full">
                {company}
              </span>
            )}
          </div>
          <span class="news-time text-[11px] text-gray-500 shrink-0">{newsDate.toLocaleDateString(dateLocale, { month: 'short', day: 'numeric' })}</span>
        </div>

        <!-- Headline -->
        <h3 class="text-lg font-bold text-white mb-2 leading-tight group-hover:text-neon-blue transition-colors">
          {headline}
        </h3>

        <!-- Summary -->
        <p class="text-sm text-gray-400 leading-relaxed mb-3 ">
          {summary}
        </p>

        <!-- Bottom row: source + link icon -->
        <div class="flex items-center justify-between">
          <span class="text-[11px] text-gray-500 flex items-center gap-1.5">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
            </svg>
            {source}
          </span>
          <svg class="w-3.5 h-3.5 text-neon-blue/50 group-hover:text-neon-blue transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </div>
      </div>
    </article>
  </a>
) : (
  <!-- Static news card (no link) -->
  <div class="group block news-card" data-date={date} data-lang={lang}>
    <article class="relative overflow-hidden rounded-xl border transition-all duration-300 bg-dark-700/40 border-dark-500/30">
      <div class="p-4">
        <!-- Top row: dot + company + time -->
        <div class="flex items-center justify-between mb-3">
          <div class="flex items-center gap-2">
            <span class="news-dot w-2 h-2 rounded-full shrink-0 bg-dark-400"></span>
            <span class="inline-flex items-center gap-1 px-2 py-0.5 text-[10px] font-semibold rounded-full bg-gray-500/10 text-gray-400 border border-gray-500/20">
              <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              {lang === 'ar' ? 'خبر' : 'News'}
            </span>
            {company && (
              <span class="text-[11px] font-medium text-gray-500 bg-dark-600/50 px-2 py-0.5 rounded-full">
                {company}
              </span>
            )}
          </div>
          <span class="news-time text-[11px] text-gray-500 shrink-0">{newsDate.toLocaleDateString(dateLocale, { month: 'short', day: 'numeric' })}</span>
        </div>

        <!-- Headline -->
        <h3 class="text-lg font-bold text-white mb-2 leading-tight">
          {headline}
        </h3>

        <!-- Summary -->
        <p class="text-sm text-gray-400 leading-relaxed mb-3 ">
          {summary}
        </p>

        <!-- Bottom row: source -->
        <div class="flex items-center justify-between">
          <span class="text-[11px] text-gray-500 flex items-center gap-1.5">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
            </svg>
            {source}
          </span>
          <svg class="w-3.5 h-3.5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
      </div>
    </article>
  </div>
)}

<script>
  function updateNewsTime() {
    const cards = document.querySelectorAll('.news-card');
    const now = new Date();

    cards.forEach(card => {
      const dateStr = card.getAttribute('data-date');
      const lang = card.getAttribute('data-lang') || 'ar';
      if (!dateStr) return;

      const newsDate = new Date(dateStr);
      const diffMs = now.getTime() - newsDate.getTime();
      const diffHours = Math.floor(diffMs / (1000 * 60 * 60));
      const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));

      let timeAgo;
      if (diffHours < 1) {
        timeAgo = lang === 'ar' ? 'الآن' : 'Just now';
      } else if (diffHours < 24) {
        timeAgo = lang === 'ar' ? `منذ ${diffHours} ساعة` : `${diffHours}h ago`;
      } else if (diffDays < 7) {
        timeAgo = lang === 'ar' ? `منذ ${diffDays} يوم` : `${diffDays}d ago`;
      } else {
        timeAgo = newsDate.toLocaleDateString(lang === 'ar' ? 'ar-EG' : 'en-US', { month: 'short', day: 'numeric' });
      }

      const timeEl = card.querySelector('.news-time');
      if (timeEl) timeEl.textContent = timeAgo;

      // Update "new" indicator
      const isNew = diffHours < 24;
      const dotEl = card.querySelector('.news-dot');
      if (dotEl) {
        dotEl.classList.toggle('bg-neon-green', isNew);
        dotEl.classList.toggle('animate-pulse', isNew);
        dotEl.classList.toggle('bg-dark-400', !isNew);
      }
    });
  }

  updateNewsTime();
  // Update every minute
  setInterval(updateNewsTime, 60000);
</script>

<style>
  /* news card styles */
</style>
