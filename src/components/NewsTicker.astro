---
import type { Lang } from '../i18n/translations';
import { getCollection } from 'astro:content';

interface Props {
  lang?: Lang;
}

const { lang = 'ar' } = Astro.props;
const collectionName = lang === 'ar' ? 'news' : 'news-en';

const NEWS_EXPIRY_DAYS = 5;

let newsItems: { headline: string; date: string; source: string; sourceUrl: string; company?: string }[] = [];

try {
  const cutoff = new Date();
  cutoff.setDate(cutoff.getDate() - NEWS_EXPIRY_DAYS);
  const entries = await getCollection(collectionName as any);
  newsItems = entries
    .flatMap((e: any) => e.data)
    .filter((n: any) => !n.draft && new Date(n.date) >= cutoff)
    .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime())
    .slice(0, 15);
} catch {
  newsItems = [];
}

const prefix = `/${lang}`;

---

{newsItems.length > 0 && (
  <div class="news-ticker-wrapper bg-dark-800/90 border-b border-dark-500/20 overflow-hidden relative" dir={lang === 'ar' ? 'rtl' : 'ltr'}>
    <div class="max-w-7xl mx-auto flex items-center h-8">
      <!-- Label -->
      <a
        href={`${prefix}/news/`}
        class="shrink-0 flex items-center gap-1.5 px-3 h-full bg-neon-green/5 border-e border-dark-500/30 hover:bg-neon-green/10 transition-colors z-10"
      >
        <span class="w-1.5 h-1.5 rounded-full bg-neon-green animate-pulse"></span>
        <span class="text-[11px] font-bold text-neon-green">
          {lang === 'ar' ? 'أخبار' : 'NEWS'}
        </span>
      </a>

      <!-- Scrolling ticker -->
      <div class="ticker-track flex items-center gap-8 whitespace-nowrap">
        {[...newsItems, ...newsItems].map((item) => (
          <a
            href={item.sourceUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-[12px] text-gray-400 hover:text-white transition-colors shrink-0"
          >
            <span class="w-1 h-1 rounded-full shrink-0 bg-neon-green/60"></span>
            <span class="font-medium text-gray-300">{item.headline}</span>
            {item.company && (
              <span class="text-gray-600">— {item.company}</span>
            )}
          </a>
        ))}
      </div>
    </div>
  </div>
)}

<style>
  .news-ticker-wrapper {
    height: 32px;
  }

  .ticker-track {
    animation: ticker-scroll 60s linear infinite;
  }

  .ticker-track:hover {
    animation-play-state: paused;
  }

  @keyframes ticker-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  [dir="rtl"] .ticker-track {
    animation: ticker-scroll-rtl 60s linear infinite;
  }

  @keyframes ticker-scroll-rtl {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(50%);
    }
  }
</style>
