---
import { t } from '../i18n/translations';
import type { Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'ar' } = Astro.props;
const prefix = `/${lang}`;
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-dark-500/20 bg-dark-800/50 mt-20">
  <div class="max-w-7xl mx-auto px-4 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
      <!-- Brand -->
      <div class="md:col-span-2">
        <a href={`${prefix}/`} class="flex items-center gap-2 mb-4">
          <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-neon-blue to-neon-green flex items-center justify-center">
            <svg class="w-5 h-5 text-dark-900" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" />
            </svg>
          </div>
          <span class="text-lg font-bold text-white">AI <span class="gradient-text">DayaHimour</span></span>
        </a>
        <p class="text-gray-400 text-sm leading-relaxed max-w-md mb-6">
          {t(lang, 'footer.description')}
        </p>

        <!-- Social Links -->
        <div class="flex items-center gap-3">
          <a href="https://x.com/DayaHimour" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)" class="w-10 h-10 rounded-lg bg-dark-600/50 border border-dark-500/30 flex items-center justify-center text-gray-400 hover:text-neon-blue hover:border-neon-blue/30 transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" /></svg>
          </a>
          <a href="https://github.com/dayahimour" target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="w-10 h-10 rounded-lg bg-dark-600/50 border border-dark-500/30 flex items-center justify-center text-gray-400 hover:text-purple-400 hover:border-purple-500/30 transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" /></svg>
          </a>
          <a href="mailto:dayahimour@gmail.com" aria-label="Email" class="w-10 h-10 rounded-lg bg-dark-600/50 border border-dark-500/30 flex items-center justify-center text-gray-400 hover:text-neon-green hover:border-neon-green/30 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-white font-semibold mb-4">{t(lang, 'footer.quickLinks')}</h3>
        <ul class="space-y-2">
          <li><a href={`${prefix}/`} class="text-gray-400 hover:text-neon-blue text-sm transition-colors">{t(lang, 'nav.home')}</a></li>
          <li><a href={`${prefix}/news/`} class="text-gray-400 hover:text-neon-blue text-sm transition-colors">{t(lang, 'nav.news')}</a></li>
          <li><a href={`${prefix}/blog/`} class="text-gray-400 hover:text-neon-blue text-sm transition-colors">{t(lang, 'nav.blog')}</a></li>
          <li><a href={`${prefix}/models/`} class="text-gray-400 hover:text-neon-blue text-sm transition-colors">{t(lang, 'nav.models')}</a></li>
          <li><a href={`${prefix}/tools/`} class="text-gray-400 hover:text-neon-blue text-sm transition-colors">{t(lang, 'nav.tools')}</a></li>
          <li><a href={`${prefix}/companies/`} class="text-gray-400 hover:text-neon-blue text-sm transition-colors">{t(lang, 'nav.companies')}</a></li>
          <li><a href={`${prefix}/future/`} class="text-gray-400 hover:text-neon-blue text-sm transition-colors">{t(lang, 'nav.future')}</a></li>
          <li><a href={`${prefix}/about/`} class="text-gray-400 hover:text-neon-blue text-sm transition-colors">{t(lang, 'nav.about')}</a></li>
          <li><a href={`${prefix}/privacy/`} class="text-gray-400 hover:text-neon-blue text-sm transition-colors">{t(lang, 'footer.privacy')}</a></li>
          <li><a href={`${prefix}/cookies/`} class="text-gray-400 hover:text-neon-blue text-sm transition-colors">{t(lang, 'footer.cookies')}</a></li>
          <li><a href={`${prefix}/terms/`} class="text-gray-400 hover:text-neon-blue text-sm transition-colors">{t(lang, 'footer.terms')}</a></li>
          <li><a href={`${prefix}/contact/`} class="text-gray-400 hover:text-neon-blue text-sm transition-colors">{t(lang, 'footer.contact')}</a></li>
        </ul>
      </div>

      <!-- Categories -->
      <div>
        <h3 class="text-white font-semibold mb-4">{t(lang, 'footer.categories')}</h3>
        <ul class="space-y-2">
          <li><a href={`${prefix}/blog/`} class="text-gray-400 hover:text-neon-blue text-sm transition-colors">{t(lang, 'cat.newsAI')}</a></li>
          <li><a href={`${prefix}/blog/`} class="text-gray-400 hover:text-neon-blue text-sm transition-colors">{t(lang, 'cat.analysisLong')}</a></li>
          <li><a href={`${prefix}/models/`} class="text-gray-400 hover:text-neon-blue text-sm transition-colors">{t(lang, 'cat.modelsAI')}</a></li>
          <li><a href={`${prefix}/tools/`} class="text-gray-400 hover:text-neon-blue text-sm transition-colors">{t(lang, 'cat.toolsAI')}</a></li>
          <li><a href={`${prefix}/future/`} class="text-gray-400 hover:text-neon-blue text-sm transition-colors">{t(lang, 'nav.future')}</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="mt-12 pt-6 border-t border-dark-500/20 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-gray-500 text-sm">
        &copy; {currentYear} AI DayaHimour. {t(lang, 'footer.rights')}
      </p>
      <div class="flex items-center gap-4">
        <a href={`${prefix}/privacy/`} class="text-gray-500 hover:text-neon-blue transition-colors text-sm">{t(lang, 'footer.privacy')}</a>
        <a href={`${prefix}/cookies/`} class="text-gray-500 hover:text-neon-blue transition-colors text-sm">{t(lang, 'footer.cookies')}</a>
        <a href={`${prefix}/terms/`} class="text-gray-500 hover:text-neon-blue transition-colors text-sm">{t(lang, 'footer.terms')}</a>
        <a href={`${prefix}/contact/`} class="text-gray-500 hover:text-neon-blue transition-colors text-sm">{t(lang, 'footer.contact')}</a>
        <a href="/rss.xml" class="text-gray-500 hover:text-neon-blue transition-colors" aria-label="RSS Feed">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M6.503 20.752c0 1.794-1.456 3.248-3.251 3.248-1.796 0-3.252-1.454-3.252-3.248 0-1.794 1.456-3.248 3.252-3.248 1.795.001 3.251 1.454 3.251 3.248zm-6.503-12.572v4.811c6.05.062 10.96 4.966 11.022 11.009h4.817c-.062-8.71-7.118-15.758-15.839-15.82zm0-3.368c10.58.046 19.152 8.594 19.183 19.188h4.817c-.03-13.231-10.755-23.954-24-24v4.812z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
