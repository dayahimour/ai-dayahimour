---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-dark-500/20 bg-dark-800/50 mt-20">
  <div class="max-w-7xl mx-auto px-4 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
      <!-- Brand -->
      <div class="md:col-span-2">
        <a href="/" class="flex items-center gap-2 mb-4">
          <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-neon-blue to-neon-green flex items-center justify-center">
            <svg class="w-5 h-5 text-dark-900" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" />
            </svg>
          </div>
          <span class="text-lg font-bold text-white">AI <span class="gradient-text">DayaHimour</span></span>
        </a>
        <p class="text-gray-400 text-sm leading-relaxed max-w-md mb-6">
          مصدرك الأول لأخبار وتحليلات الذكاء الاصطناعي بالعربية. نقدم لك آخر التطورات في عالم AI، تحليلات عميقة للنماذج، مراجعات الأدوات، وتنبؤات المستقبل.
        </p>

        <!-- Newsletter -->
        <div class="glass-card p-4">
          <p class="text-sm text-white font-medium mb-1">📬 النشرة البريدية</p>
          <p class="text-xs text-gray-400 mb-3">اشترك لتصلك أحدث المقالات، تحليلات النماذج الجديدة، وأهم الأخبار التقنية أولاً بأول.</p>
          <form class="flex gap-2" onsubmit="event.preventDefault(); this.querySelector('button').textContent = '✓ تم!'; setTimeout(() => this.querySelector('button').textContent = 'اشتراك', 2000);">
            <input
              type="email"
              placeholder="بريدك الإلكتروني"
              class="flex-1 bg-dark-600 border border-dark-500/50 rounded-lg px-3 py-2 text-sm text-white placeholder-gray-500 focus:outline-none focus:border-neon-blue/50"
            />
            <button type="submit" class="btn-primary text-sm px-4 py-2">اشتراك</button>
          </form>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-white font-semibold mb-4">روابط سريعة</h3>
        <ul class="space-y-2">
          <li><a href="/" class="text-gray-400 hover:text-neon-blue text-sm transition-colors">الرئيسية</a></li>
          <li><a href="/blog" class="text-gray-400 hover:text-neon-blue text-sm transition-colors">المقالات</a></li>
          <li><a href="/models" class="text-gray-400 hover:text-neon-blue text-sm transition-colors">النماذج</a></li>
          <li><a href="/tools" class="text-gray-400 hover:text-neon-blue text-sm transition-colors">الأدوات</a></li>
          <li><a href="/future" class="text-gray-400 hover:text-neon-blue text-sm transition-colors">المستقبل</a></li>
          <li><a href="/about" class="text-gray-400 hover:text-neon-blue text-sm transition-colors">من نحن</a></li>
        </ul>
      </div>

      <!-- Categories -->
      <div>
        <h3 class="text-white font-semibold mb-4">التصنيفات</h3>
        <ul class="space-y-2">
          <li><a href="/blog" class="text-gray-400 hover:text-neon-blue text-sm transition-colors">أخبار AI</a></li>
          <li><a href="/blog" class="text-gray-400 hover:text-neon-blue text-sm transition-colors">تحليلات</a></li>
          <li><a href="/models" class="text-gray-400 hover:text-neon-blue text-sm transition-colors">نماذج AI</a></li>
          <li><a href="/tools" class="text-gray-400 hover:text-neon-blue text-sm transition-colors">أدوات AI</a></li>
          <li><a href="/future" class="text-gray-400 hover:text-neon-blue text-sm transition-colors">المستقبل</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="mt-12 pt-6 border-t border-dark-500/20 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-gray-500 text-sm">
        © {currentYear} AI DayaHimour. جميع الحقوق محفوظة.
      </p>
      <div class="flex items-center gap-4">
        <a href="/rss.xml" class="text-gray-500 hover:text-neon-blue transition-colors" aria-label="RSS Feed">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M6.503 20.752c0 1.794-1.456 3.248-3.251 3.248-1.796 0-3.252-1.454-3.252-3.248 0-1.794 1.456-3.248 3.252-3.248 1.795.001 3.251 1.454 3.251 3.248zm-6.503-12.572v4.811c6.05.062 10.96 4.966 11.022 11.009h4.817c-.062-8.71-7.118-15.758-15.839-15.82zm0-3.368c10.58.046 19.152 8.594 19.183 19.188h4.817c-.03-13.231-10.755-23.954-24-24v4.812z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
