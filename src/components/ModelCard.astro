---
interface Props {
  name: string;
  company: string;
  description: string;
  strengths: string[];
  type: string;
  releaseDate?: string;
  slug?: string;
  rating?: string;
  logo?: string;
  lang?: string;
}

const { name, company, description, strengths, type, releaseDate, slug, rating, logo, lang = 'ar' } = Astro.props;

const typeColors: Record<string, string> = {
  'لغوي': 'from-neon-blue to-blue-600',
  'صور': 'from-purple-500 to-pink-500',
  'فيديو': 'from-neon-green to-emerald-600',
  'صوت': 'from-yellow-500 to-orange-500',
  'متعدد': 'from-neon-blue to-neon-green',
  'Language': 'from-neon-blue to-blue-600',
  'Image': 'from-purple-500 to-pink-500',
  'Video': 'from-neon-green to-emerald-600',
  'Audio': 'from-yellow-500 to-orange-500',
  'Multimodal': 'from-neon-blue to-neon-green',
};

const gradientClass = typeColors[type] || typeColors['لغوي'] || 'from-neon-blue to-blue-600';
const finalHref = slug ? `/${lang}/blog/${slug}` : '#';
---

<a href={finalHref} class={`block glass-card p-6 group hover:border-neon-blue/40 transition-all duration-300 hover:shadow-lg hover:shadow-neon-blue/10 relative overflow-hidden ${!slug && 'cursor-default'}`}>
  <!-- Glowing Overlay -->
  <div class="absolute inset-0 bg-gradient-to-br from-neon-blue/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
  
  <!-- Header -->
  <div class="flex items-start justify-between mb-4 relative z-10">
    <div class="flex items-center gap-3">
      {logo && (
        <div class="w-10 h-10 rounded-lg bg-white/5 flex items-center justify-center p-1.5 flex-shrink-0">
          <img src={logo} alt={company} class="w-7 h-7 object-contain" loading="lazy" />
        </div>
      )}
      <div>
        <h3 class="text-xl font-bold text-white group-hover:text-neon-blue transition-colors flex items-center gap-2">
          {name}
          {slug && (
            <svg class="w-4 h-4 opacity-0 group-hover:opacity-100 transition-all -translate-x-2 group-hover:translate-x-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          )}
        </h3>
        <p class="text-sm text-gray-400 mt-1">{company}</p>
      </div>
    </div>
    <div class="flex flex-col items-end gap-2">
      <span class={`px-3 py-1 text-xs font-medium rounded-full bg-gradient-to-r ${gradientClass} text-white shadow-sm`}>
        {type}
      </span>
    </div>
  </div>

  <!-- Description -->
  <p class="text-sm text-gray-300 mb-5 leading-relaxed relative z-10">{description}</p>

  <!-- Strengths -->
  <div class="space-y-3 relative z-10">
    <p class="text-xs text-neon-blue/80 font-medium tracking-wide">أبرز المميزات:</p>
    <div class="flex flex-wrap gap-2">
      {strengths.map(s => (
        <span class="inline-block px-2.5 py-1 text-[11px] rounded bg-dark-700 text-gray-300 border border-dark-500/50 group-hover:border-neon-blue/20 transition-colors">
          {s}
        </span>
      ))}
    </div>
  </div>

  {releaseDate && (
    <div class="mt-5 pt-4 border-t border-dark-600/50 flex justify-between items-center text-xs text-gray-500 relative z-10">
      <span>📅 {releaseDate}</span>
      {slug ? (
        <span class="text-neon-blue font-medium group-hover:text-neon-green transition-colors">مراجعة مفصلة ←</span>
      ) : (
        <span class="text-yellow-500/80">قريباً...</span>
      )}
    </div>
  )}
</a>
