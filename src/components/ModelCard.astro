---
interface Props {
  name: string;
  company: string;
  description: string;
  strengths: string[];
  type: string;
  releaseDate?: string;
}

const { name, company, description, strengths, type, releaseDate } = Astro.props;

const typeColors: Record<string, string> = {
  'لغوي': 'from-neon-blue to-blue-600',
  'صور': 'from-purple-500 to-pink-500',
  'فيديو': 'from-neon-green to-emerald-600',
  'صوت': 'from-yellow-500 to-orange-500',
  'متعدد': 'from-neon-blue to-neon-green',
};

const gradientClass = typeColors[type] || typeColors['لغوي'];
---

<div class="glass-card p-6 group hover:border-neon-blue/30">
  <!-- Header -->
  <div class="flex items-start justify-between mb-4">
    <div>
      <h3 class="text-lg font-bold text-white group-hover:text-neon-blue transition-colors">{name}</h3>
      <p class="text-sm text-gray-400">{company}</p>
    </div>
    <span class={`px-3 py-1 text-xs font-medium rounded-full bg-gradient-to-r ${gradientClass} text-white`}>
      {type}
    </span>
  </div>

  <!-- Description -->
  <p class="text-sm text-gray-400 mb-4 leading-relaxed">{description}</p>

  <!-- Strengths -->
  <div class="space-y-2">
    <p class="text-xs text-gray-500 font-medium">نقاط القوة:</p>
    <div class="flex flex-wrap gap-2">
      {strengths.map(s => (
        <span class="inline-block px-2 py-1 text-xs rounded-md bg-dark-600 text-gray-300 border border-dark-500/50">
          {s}
        </span>
      ))}
    </div>
  </div>

  {releaseDate && (
    <div class="mt-4 pt-4 border-t border-dark-500/30 text-xs text-gray-500">
      📅 تاريخ الإطلاق: {releaseDate}
    </div>
  )}
</div>
