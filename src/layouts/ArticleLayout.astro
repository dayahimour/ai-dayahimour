---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { t } from '../i18n/translations';
import type { Lang } from '../i18n/translations';

interface Props {
  title: string;
  description: string;
  date: string;
  category: string;
  tags: string[];
  image?: string;
  author?: string;
  headings: { depth: number; slug: string; text: string }[];
  lang?: Lang;
}

const { title, description, date, category, tags, image, author, headings, lang = 'ar' } = Astro.props;
const finalAuthor = author || (lang === 'ar' ? 'فريق AI DayaHimour' : 'AI DayaHimour Team');

const dateLocale = lang === 'ar' ? 'ar-EG' : 'en-US';
const formattedDate = new Date(date).toLocaleDateString(dateLocale, {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

// Estimate reading time
const wordsPerMin = lang === 'ar' ? 200 : 250;
const content = await Astro.slots.render('default');
const wordCount = content.replace(/<[^>]*>/g, '').split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(wordCount / wordsPerMin));

const siteUrl = 'https://dayahimour.org';
const langPrefix = `/${lang}`;

// Article Structured Data (JSON-LD)
const articleSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BlogPosting",
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": new URL(Astro.url.pathname, Astro.site).toString()
      },
      "headline": title,
      "description": description,
      "image": image ? new URL(image, Astro.site).toString() : new URL('/images/og-default.png', Astro.site).toString(),
      "datePublished": new Date(date).toISOString(),
      "dateModified": new Date(date).toISOString(),
      "author": {
        "@type": "Person",
        "name": finalAuthor
      },
      "publisher": {
        "@type": "Organization",
        "name": "AI DayaHimour",
        "url": siteUrl,
        "logo": {
          "@type": "ImageObject",
          "url": `${siteUrl}/favicon-192x192.png`
        }
      },
      "inLanguage": lang,
      "keywords": tags.join(", "),
      "wordCount": wordCount,
      "timeRequired": `PT${readingTime}M`
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": t(lang, 'nav.home'),
          "item": `${siteUrl}${langPrefix}/`
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": t(lang, 'nav.blog'),
          "item": `${siteUrl}${langPrefix}/blog/`
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": title
        }
      ]
    }
  ]
};
---

<BaseLayout title={title} description={description} image={image} type="article" lang={lang}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <meta property="article:published_time" content={new Date(date).toISOString()} />
    <meta property="article:modified_time" content={new Date(date).toISOString()} />
    <meta property="article:section" content={category} />
    {tags.map(tag => <meta property="article:tag" content={tag} />)}
  </Fragment>

  <article class="max-w-5xl mx-auto px-4 py-12">
    <!-- Breadcrumb -->
    <nav class="mb-6 text-sm text-gray-500" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 flex-wrap">
        <li><a href={`${langPrefix}/`} class="hover:text-neon-blue transition-colors">{t(lang, 'nav.home')}</a></li>
        <li class={lang === 'ar' ? 'before:content-["‹"]' : 'before:content-["›"]'}></li>
        <li><a href={`${langPrefix}/blog/`} class="hover:text-neon-blue transition-colors">{t(lang, 'nav.blog')}</a></li>
        <li class={lang === 'ar' ? 'before:content-["‹"]' : 'before:content-["›"]'}></li>
        <li class="text-gray-400 truncate max-w-[200px]">{title}</li>
      </ol>
    </nav>

    <!-- Article Header -->
    <header class="mb-10">
      <div class="flex items-center gap-3 mb-4">
        <span class="tag">{category}</span>
        <span class="text-gray-500 text-sm">{formattedDate}</span>
        <span class="text-gray-500 text-sm flex items-center gap-1">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          {readingTime} {t(lang, 'article.readingTime')}
        </span>
      </div>

      <h1 class="text-3xl md:text-5xl font-bold text-white leading-tight mb-4">
        {title}
      </h1>

      <p class="text-lg text-gray-400 mb-6">{description}</p>

      <div class="flex items-center gap-3 text-gray-400">
        <div class="w-10 h-10 rounded-full bg-gradient-to-br from-neon-blue to-neon-green flex items-center justify-center text-dark-900 font-bold text-sm">
          {finalAuthor.charAt(0)}
        </div>
        <div>
          <p class="text-white font-medium text-sm">{finalAuthor}</p>
          <p class="text-xs text-gray-500">{formattedDate}</p>
        </div>
      </div>
    </header>

    <!-- Cover Image -->
    {image && (
      <figure class="mb-10 rounded-2xl overflow-hidden border border-dark-500/30 bg-dark-800 max-w-3xl mx-auto">
        <img src={image} alt={title} title={title} class="w-full aspect-[16/9] object-contain" width="1200" height="675" loading="eager" fetchpriority="high" />
      </figure>
    )}

    <!-- Content Grid: TOC + Article -->
    <div class={`flex flex-col lg:flex-row gap-10 ${lang === 'en' ? 'lg:flex-row' : ''}`}>
      <!-- Table of Contents (Desktop) -->
      {headings.length > 0 && (
        <aside class="hidden lg:block lg:w-64 shrink-0">
          <div class="sticky top-24">
            <TableOfContents headings={headings} lang={lang} />
          </div>
        </aside>
      )}

      <!-- Article Content -->
      <div class="flex-1 prose-dark">
        <slot />
      </div>
    </div>

    <!-- Tags -->
    <div class="mt-12 pt-8 border-t border-dark-500/30">
      <div class="flex flex-wrap gap-2">
        {tags.map(tag => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    </div>

    <!-- removed view counter to comply with AdSense -->

    <!-- Share Buttons -->
    <div class="mt-8 flex items-center gap-4">
      <span class="text-gray-400 text-sm">{t(lang, 'article.share')}</span>
      <a
        href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(Astro.url.href)}`}
        target="_blank"
        rel="noopener"
        class="w-10 h-10 rounded-full bg-dark-600 hover:bg-neon-blue/20 flex items-center justify-center transition-colors"
        aria-label="Share on Twitter"
      >
        <svg class="w-5 h-5 text-gray-400 hover:text-neon-blue" fill="currentColor" viewBox="0 0 24 24">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
        </svg>
      </a>
      <a
        href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.url.href)}`}
        target="_blank"
        rel="noopener"
        class="w-10 h-10 rounded-full bg-dark-600 hover:bg-neon-blue/20 flex items-center justify-center transition-colors"
        aria-label="Share on Facebook"
      >
        <svg class="w-5 h-5 text-gray-400 hover:text-neon-blue" fill="currentColor" viewBox="0 0 24 24">
          <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
        </svg>
      </a>
      <a
        href={`https://t.me/share/url?url=${encodeURIComponent(Astro.url.href)}&text=${encodeURIComponent(title)}`}
        target="_blank"
        rel="noopener"
        class="w-10 h-10 rounded-full bg-dark-600 hover:bg-neon-blue/20 flex items-center justify-center transition-colors"
        aria-label="Share on Telegram"
      >
        <svg class="w-7 h-7 text-gray-400 hover:text-[#29a9eb] transition-colors" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="16" cy="16" r="14" fill="currentColor"/>
          <path d="M22.9866 10.2088C23.1112 9.40332 22.3454 8.76755 21.6292 9.082L7.36482 15.3448C6.85123 15.5703 6.8888 16.3483 7.42147 16.5179L10.3631 17.4547C10.9246 17.6335 11.5325 17.541 12.0228 17.2023L18.655 12.6203C18.855 12.4821 19.073 12.7665 18.9021 12.9426L14.1281 17.8646C13.665 18.3421 13.7569 19.1512 14.314 19.5005L19.659 22.8523C20.2585 23.2282 21.0297 22.8506 21.1418 22.1261L22.9866 10.2088Z" fill="white"/>
        </svg>
      </a>
      <div class="relative group">
        <button
          id="copy-link-btn"
          onclick="copyLinkToClipboard()"
          class="w-10 h-10 rounded-full bg-dark-600 hover:bg-neon-blue/20 flex items-center justify-center transition-colors"
          aria-label="Copy Link"
        >
          <svg id="copy-icon" class="w-5 h-5 text-gray-400 hover:text-neon-blue transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
          </svg>
          <svg id="copy-check" class="w-5 h-5 text-neon-green hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
          </svg>
        </button>
        <span id="copy-tooltip" class="absolute -top-8 left-1/2 -translate-x-1/2 px-2 py-1 rounded-md bg-dark-700 text-xs text-white whitespace-nowrap opacity-0 transition-opacity duration-200 pointer-events-none">{lang === 'ar' ? 'تم النسخ!' : 'Copied!'}</span>
      </div>
    </div>
  </article>

  <!-- Related posts slot (rendered inside <main>, before the footer) -->
  <slot name="related" />
</BaseLayout>

<script is:inline>
  function copyLinkToClipboard() {
    const url = window.location.href;
    navigator.clipboard.writeText(url).catch(() => {
      /* silently ignore */
    });
    const icon = document.getElementById('copy-icon');
    const check = document.getElementById('copy-check');
    const tooltip = document.getElementById('copy-tooltip');
    if (icon) icon.classList.add('hidden');
    if (check) check.classList.remove('hidden');
    if (tooltip) tooltip.classList.remove('opacity-0');
    setTimeout(() => {
      if (icon) icon.classList.remove('hidden');
      if (check) check.classList.add('hidden');
      if (tooltip) tooltip.classList.add('opacity-0');
    }, 2000);
  }
</script>
