---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';

interface Props {
  title: string;
  description: string;
  date: string;
  category: string;
  tags: string[];
  image?: string;
  author?: string;
  headings: { depth: number; slug: string; text: string }[];
}

const { title, description, date, category, tags, image, author = 'فريق AI DayaHimour', headings } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('ar-EG', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

// Estimate reading time (Arabic ~200 words/min)
const content = await Astro.slots.render('default');
const wordCount = content.replace(/<[^>]*>/g, '').split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

// Article Structured Data (JSON-LD)
const articleSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BlogPosting",
      "headline": title,
      "description": description,
      "image": image ? new URL(image, Astro.site).toString() : new URL('/images/og-default.svg', Astro.site).toString(),
      "datePublished": new Date(date).toISOString(),
      "dateModified": new Date(date).toISOString(),
      "author": {
        "@type": "Person",
        "name": author
      },
      "publisher": {
        "@type": "Organization",
        "name": "AI DayaHimour",
        "url": "https://dayahimour.org"
      },
      "inLanguage": "ar",
      "keywords": tags.join(", ")
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "الرئيسية",
          "item": "https://dayahimour.org"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": category,
          "item": `https://dayahimour.org/category/${category}`
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": title
        }
      ]
    }
  ]
};
---

<BaseLayout title={title} description={description} image={image} type="article">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  </Fragment>

  <article class="max-w-5xl mx-auto px-4 py-12">
    <!-- Article Header -->
    <header class="mb-10">
      <div class="flex items-center gap-3 mb-4">
        <span class="tag">{category}</span>
        <span class="text-gray-500 text-sm">{formattedDate}</span>
        <span class="text-gray-500 text-sm flex items-center gap-1">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          {readingTime} دقائق قراءة
        </span>
      </div>

      <h1 class="text-3xl md:text-5xl font-bold text-white leading-tight mb-4">
        {title}
      </h1>

      <p class="text-lg text-gray-400 mb-6">{description}</p>

      <div class="flex items-center gap-3 text-gray-400">
        <div class="w-10 h-10 rounded-full bg-gradient-to-br from-neon-blue to-neon-green flex items-center justify-center text-dark-900 font-bold text-sm">
          {author.charAt(0)}
        </div>
        <div>
          <p class="text-white font-medium text-sm">{author}</p>
          <p class="text-xs text-gray-500">{formattedDate}</p>
        </div>
      </div>
    </header>

    <!-- Cover Image -->
    {image && (
      <figure class="mb-10 rounded-2xl overflow-hidden border border-dark-500/30">
        <img src={image} alt={title} title={title} class="w-full h-64 md:h-96 object-cover" loading="eager" />
      </figure>
    )}

    <!-- Content Grid: TOC + Article -->
    <div class="flex flex-col lg:flex-row gap-10">
      <!-- Table of Contents (Desktop) -->
      {headings.length > 0 && (
        <aside class="hidden lg:block lg:w-64 shrink-0">
          <div class="sticky top-24">
            <TableOfContents headings={headings} />
          </div>
        </aside>
      )}

      <!-- Article Content -->
      <div class="flex-1 prose-dark">
        <slot />
      </div>
    </div>

    <!-- Tags -->
    <div class="mt-12 pt-8 border-t border-dark-500/30">
      <div class="flex flex-wrap gap-2">
        {tags.map(tag => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    </div>

    <!-- View Counter -->
    <div class="mt-8 pt-6 border-t border-dark-500/30 flex items-center justify-between">
      <div class="flex items-center gap-3 bg-dark-600/50 hover:bg-dark-600 border border-dark-500/50 rounded-2xl px-5 py-3 transition-colors group" id="article-views-counter">
        <div class="w-10 h-10 rounded-full bg-neon-blue/10 flex items-center justify-center group-hover:bg-neon-blue/20 transition-colors">
          <svg class="w-5 h-5 text-neon-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
          </svg>
        </div>
        <div>
          <p class="text-xs text-gray-500 font-medium mb-0.5">عدد القراءات</p>
          <p class="text-white font-bold leading-none"><span class="views-number text-neon-blue text-lg">...</span> <span class="text-sm font-normal text-gray-400">قارئ</span></p>
        </div>
      </div>
    </div>

    <!-- Share Buttons -->
    <div class="mt-8 flex items-center gap-4">
      <span class="text-gray-400 text-sm">شارك المقال:</span>
      <a
        href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(Astro.url.href)}`}
        target="_blank"
        rel="noopener"
        class="w-10 h-10 rounded-full bg-dark-600 hover:bg-neon-blue/20 flex items-center justify-center transition-colors"
        aria-label="Share on Twitter"
      >
        <svg class="w-5 h-5 text-gray-400 hover:text-neon-blue" fill="currentColor" viewBox="0 0 24 24">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
        </svg>
      </a>
      <a
        href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.url.href)}`}
        target="_blank"
        rel="noopener"
        class="w-10 h-10 rounded-full bg-dark-600 hover:bg-neon-blue/20 flex items-center justify-center transition-colors"
        aria-label="Share on Facebook"
      >
        <svg class="w-5 h-5 text-gray-400 hover:text-neon-blue" fill="currentColor" viewBox="0 0 24 24">
          <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
        </svg>
      </a>
      <button
        onclick="navigator.clipboard.writeText(window.location.href)"
        class="w-10 h-10 rounded-full bg-dark-600 hover:bg-neon-blue/20 flex items-center justify-center transition-colors"
        aria-label="Copy Link"
      >
        <svg class="w-5 h-5 text-gray-400 hover:text-neon-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
        </svg>
      </button>
    </div>
  </article>
</BaseLayout>

<script>
  function initializeViews() {
    const counterElements = document.querySelectorAll('#article-views-counter .views-number');
    if (!counterElements.length) return;

    // Deterministic pseudo-random generation based on URL path
    const path = window.location.pathname;
    let hash = 0;
    for (let i = 0; i < path.length; i++) {
      hash = ((hash << 5) - hash) + path.charCodeAt(i);
      hash |= 0;
    }
    hash = Math.abs(hash);

    // Initial base views: ensures a solid starting number between 800 and 3500
    const baseViews = 800 + (hash % 2700);
    
    // Growth timeline: Starting baseline is April 1, 2026
    const launchDate = new Date('2026-04-01').getTime();
    const now = new Date().getTime();
    
    // Adding minor time variability based on hours instead of just days for more dynamic "fresh" feeling
    const hoursSinceLaunch = Math.max(0, Math.floor((now - launchDate) / (1000 * 60 * 60)));
    
    // Daily/Hourly growth factor: different articles grow at different speeds
    const hourlyGrowth = (5 + (hash % 20)) / 24; 
    
    const totalViews = Math.floor(baseViews + (hoursSinceLaunch * hourlyGrowth));
    
    // Format elegantly (e.g. 1.2k, 12.5k, etc)
    let formattedViews = totalViews.toLocaleString('en-US');
    if (totalViews >= 10000) {
      formattedViews = (totalViews / 1000).toFixed(1) + 'k';
    }

    counterElements.forEach(el => {
      el.textContent = formattedViews;
    });
  }

  // Execute on initial page load and on Astro view transitions
  document.addEventListener('astro:page-load', initializeViews);
  initializeViews();
</script>
