---
// Root index: fallback redirect. Cloudflare Worker handles geo-redirect for production.
// This page is only hit if Worker is not active (dev mode).
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="robots" content="noindex, follow" />
    <link rel="canonical" href="https://dayahimour.org/ar/" />
    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>AI DayaHimour</title>
    <!-- Immediate client-side redirect - runs before page renders -->
    <script is:inline>
      // Immediate redirect - no delay, no visible content
      const lang = navigator.language.toLowerCase();
      window.location.replace('/' + (lang.startsWith('ar') ? 'ar' : 'en') + '/');
    </script>
    <!-- Meta refresh as final fallback -->
    <meta http-equiv="refresh" content="0; url=/ar/" />
  </head>
  <body style="background-color: #050a12; margin: 0; padding: 0;">
  </body>
</html>
