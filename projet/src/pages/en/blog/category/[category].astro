---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const lang = 'en';

export async function getStaticPaths() {
  const posts = (await getCollection('blog-en')).filter(p => !p.data.draft);
  const categories = [...new Set(posts.map(p => p.data.category))];
  return categories.map(category => ({
    params: { category },
    props: {
      posts: posts
        .filter(p => p.data.category === category)
        .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()),
      category,
    },
  }));
}

const { posts, category } = Astro.props;
const categoryTitle = category.charAt(0).toUpperCase() + category.slice(1);
---

<BaseLayout title={categoryTitle} description={`All ${categoryTitle} articles`} lang={lang}>
  <div class="max-w-7xl mx-auto px-4 py-12">
    <div class="mb-12">
      <nav class="text-sm text-gray-400 mb-4">
        <a href="/en/" class="hover:text-white">Home</a>
        <span class="mx-2">/</span>
        <a href="/en/blog/" class="hover:text-white">Blog</a>
        <span class="mx-2">/</span>
        <span class="text-neon-blue">{categoryTitle}</span>
      </nav>
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">
        <span class="gradient-text">{categoryTitle}</span> Articles
      </h1>
      <p class="text-gray-400 text-lg">{posts.length} articles in this category</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.map(post => (
        <ArticleCard
          title={post.data.title}
          description={post.data.description}
          date={post.data.date}
          category={post.data.category}
          slug={post.slug}
          image={post.data.image}
          lang={lang}
        />
      ))}
    </div>
  </div>
</BaseLayout>
