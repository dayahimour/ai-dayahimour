---
interface Model {
  id: string;
  name: string;
  color: string;
  textColor: string;
  iconText?: string;
  iconBg?: string;
  iconColor?: string;
}

interface Metric {
  name: string;
  scores: Record<string, number>;
}

interface Props {
  title?: string;
  models: Model[];
  metrics: Metric[];
  maxScore?: number;
}

const { title, models, metrics, maxScore = 100 } = Astro.props;
---

<div dir="rtl" class="w-full bg-gradient-to-br from-[#0f172a] to-[#1e293b] rounded-2xl p-6 md:p-8 my-8 border border-blue-400/10 shadow-[0_8px_30px_rgb(0,0,0,0.4)] relative overflow-hidden">
  
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[80%] h-40 bg-blue-500/5 blur-[120px] pointer-events-none"></div>
  
  {title && (
    <h3 class="text-slate-400 text-xs md:text-sm font-semibold text-center mb-8 tracking-widest uppercase">
      {title}
    </h3>
  )}

  <!-- Legend -->
  <div class="flex flex-wrap justify-center gap-6 md:gap-10 mb-14">
    {models.map(model => (
      <div class="flex items-center gap-3">
        {model.iconText ? (
          <div class={`flex items-center justify-center w-5 h-5 rounded-[4px] ${model.iconBg || 'bg-slate-800'} ${model.iconColor || 'text-white'} text-[10px] font-black shadow-md`}>
            {model.iconText}
          </div>
        ) : (
          <div class={`w-3.5 h-3.5 rounded-sm shadow-sm ${model.color.split(' ')[0]}`}></div>
        )}
        <span class="text-slate-300 text-[13px] md:text-sm font-medium">{model.name}</span>
      </div>
    ))}
  </div>

  <!-- Chart Layout -->
  <div class="flex flex-col lg:flex-row justify-around gap-12 lg:gap-4 items-end">
    {metrics.map(metric => (
      <div class="flex flex-col items-center flex-1 w-full relative group/metric">
        
        <!-- Bars Container -->
        <div class="flex items-end justify-center gap-3 sm:gap-4 w-full h-[220px] sm:h-[280px] border-b border-white/10 pb-1">
          {models.map(model => {
            const score = metric.scores[model.id] || 0;
            const heightPercent = Math.min((score / maxScore) * 100, 100);
            
            return (
              <div class="flex flex-col items-center justify-end relative h-full w-12 sm:w-16 group/bar">
                
                <!-- Score Value -->
                <span class={`mb-2.5 text-[11px] sm:text-[13px] font-bold opacity-90 transition-all duration-300 group-hover/bar:-translate-y-1 ${model.textColor}`}>
                  {score.toFixed(1)}
                </span>
                
                <!-- The Bar Fill -->
                <div 
                  class={`w-full rounded-t-xl transition-all duration-700 ease-out relative shadow-[0_-5px_15px_rgba(0,0,0,0.2)] hover:brightness-110 flex items-start justify-center pt-3 overflow-hidden ${model.color}`}
                  style={`height: ${heightPercent}%`}
                >
                  <!-- Glass/Reflection Effect overlay -->
                  <div class="absolute inset-0 bg-gradient-to-r from-white/0 via-white/20 to-white/0 opacity-0 group-hover/bar:opacity-100 transition-opacity duration-300"></div>
                  <div class="absolute inset-0 bg-gradient-to-b from-white/20 to-transparent opacity-50"></div>
                  
                  <!-- Logo Inside Bar -->
                  {model.iconText && (
                    <div class={`flex items-center justify-center w-8 h-8 sm:w-10 sm:h-10 rounded-lg ${model.iconBg || 'bg-[#0f172a]'} ${model.iconColor || 'text-white'} shadow-[inset_0_-2px_4px_rgba(0,0,0,0.6)] text-sm sm:text-base font-black z-10 transition-transform duration-300 hover:scale-105`}>
                      {model.iconText}
                    </div>
                  )}
                </div>
              </div>
            );
          })}
        </div>
        
        <!-- Metric Name Label -->
        <div class="mt-5 text-center transition-colors duration-300 group-hover/metric:text-white">
          <span class="text-slate-300 text-xs sm:text-[13px] font-semibold tracking-wide">{metric.name}</span>
        </div>
      </div>
    ))}
  </div>
</div>
