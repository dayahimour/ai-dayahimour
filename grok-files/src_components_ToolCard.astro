---
interface Props {
  name: string;
  description: string;
  category: string;
  url: string;
  free?: boolean;
}

const { name, description, category, url, free = false } = Astro.props;
---

<a href={url} target="_blank" rel="noopener noreferrer" class="glass-card p-6 group block hover:border-neon-blue/30">
  <div class="flex items-start justify-between mb-3">
    <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-neon-blue/20 to-neon-green/20 border border-dark-500/50 flex items-center justify-center group-hover:from-neon-blue/30 group-hover:to-neon-green/30 transition-colors">
      <svg class="w-6 h-6 text-neon-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
      </svg>
    </div>
    {free && (
      <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-neon-green/10 text-neon-green border border-neon-green/20">
        مجاني
      </span>
    )}
  </div>

  <h3 class="text-lg font-bold text-white mb-1 group-hover:text-neon-blue transition-colors">{name}</h3>
  <p class="text-sm text-gray-400 mb-3 leading-relaxed">{description}</p>

  <div class="flex items-center justify-between">
    <span class="tag text-xs">{category}</span>
    <span class="flex items-center gap-1 text-xs text-neon-blue opacity-0 group-hover:opacity-100 transition-opacity">
      زيارة
      <svg class="w-3 h-3 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
      </svg>
    </span>
  </div>
</a>
