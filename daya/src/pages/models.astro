---

<BaseLayout title="النماذج العالمية" description="دليل شامل لأهم وأحدث نماذج الذكاء الاصطناعي الرائدة عالمياً مع مواصفاتها ونقاط قوتها">
  <div class="max-w-7xl mx-auto px-4 py-12">
    <!-- Header -->
    <div class="mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">
        أقوى نماذج <span class="gradient-text">الذكاء الاصطناعي (أبريل 2026)</span>
      </h1>
      <p class="text-gray-400 text-lg max-w-2xl">
        استعرض قائمة أقوى النماذج الصينية والعالمية التي تتصدر المؤشرات حالياً، اضغط على النموذج لقراءة التحليل التقييمي المفصل له.
      </p>
    </div>

    <!-- Models Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
      {models.map((model) => (
        <ModelCard {...model} />
      ))}
    </div>

    <!-- Comparison Tables -->
    <section class="space-y-16">
      <!-- LLM & Multimodal -->
      <div>
        <h2 class="section-title flex items-center gap-3 mb-8">
          <span class="w-8 h-8 rounded-lg bg-neon-blue/10 flex items-center justify-center text-neon-blue">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </span>
          تقييم النماذج اللغوية والمتعددة (أبريل 2026)
        </h2>
        <div class="glass-card overflow-hidden overflow-x-auto">
          <table class="w-full text-sm text-right">
            <thead>
              <tr class="border-b border-dark-500/30 bg-dark-800/80">
                <th class="p-4 text-white font-semibold">النموذج</th>
                <th class="p-4 text-white font-semibold">SimpleBench (منطق)</th>
                <th class="p-4 text-white font-semibold">SWE-bench (برمجة)</th>
                <th class="p-4 text-white font-semibold">التقييم العام</th>
              </tr>
            </thead>
            <tbody>
              {models.filter(m => m.type === 'لغوي' || m.type === 'متعدد').map((model, i) => (
                <tr class:list={['border-b border-dark-500/20 hover:bg-white/5 transition-colors', i % 2 === 0 ? 'bg-dark-700/20' : '']}>
                  <td class="p-4">
                    <a href={model.slug ? `/blog/${model.slug}` : '#'} class="text-neon-blue font-medium hover:underline">{model.name}</a>
                  </td>
                  <td class="p-4 text-gray-300">{(model.name === 'Gemini 3.1 Pro' ? '79.6%' : (model.name === 'GPT-5.4' ? '74.1%' : (model.name === 'Claude Opus 4.6' ? '67.6%' : '70%+')))}</td>
                  <td class="p-4 text-gray-300">{(model.name === 'Claude Opus 4.6' ? '78.7%' : (model.name === 'GPT-5.4' ? '76.9%' : '70%+'))}</td>
                  <td class="p-4 text-neon-green font-bold">9.0+</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <!-- Image Generation -->
      <div>
        <h2 class="section-title flex items-center gap-3 mb-8">
          <span class="w-8 h-8 rounded-lg bg-neon-purple/10 flex items-center justify-center text-neon-purple">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </span>
          تقييم نماذج توليد الصور
        </h2>
        <div class="glass-card overflow-hidden overflow-x-auto">
          <table class="w-full text-sm text-right">
            <thead>
              <tr class="border-b border-dark-500/30 bg-dark-800/80">
                <th class="p-4 text-white font-semibold">النموذج</th>
                <th class="p-4 text-white font-semibold">الجمالية</th>
                <th class="p-4 text-white font-semibold">الواقعية</th>
                <th class="p-4 text-white font-semibold">التقييم</th>
              </tr>
            </thead>
            <tbody>
              {models.filter(m => m.type === 'صور').map((model, i) => (
                <tr class:list={['border-b border-dark-500/20 hover:bg-white/5 transition-colors', i % 2 === 0 ? 'bg-dark-700/20' : '']}>
                  <td class="p-4">
                    <a href={model.slug ? `/blog/${model.slug}` : '#'} class="text-neon-purple font-medium hover:underline">{model.name}</a>
                  </td>
                  <td class="p-4 text-gray-300">{(model.name === 'Midjourney v8' ? '⭐⭐⭐⭐⭐' : '⭐⭐⭐⭐')}</td>
                  <td class="p-4 text-gray-300">{(model.name === 'FLUX.2 Pro' ? '⭐⭐⭐⭐⭐' : '⭐⭐⭐⭐')}</td>
                  <td class="p-4 text-neon-green font-bold">9.2+</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <!-- Video Generation -->
      <div>
        <h2 class="section-title flex items-center gap-3 mb-8">
          <span class="w-8 h-8 rounded-lg bg-neon-green/10 flex items-center justify-center text-neon-green">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </span>
          تقييم نماذج توليد الفيديو
        </h2>
        <div class="glass-card overflow-hidden overflow-x-auto">
          <table class="w-full text-sm text-right">
            <thead>
              <tr class="border-b border-dark-500/30 bg-dark-800/80">
                <th class="p-4 text-white font-semibold">النموذج</th>
                <th class="p-4 text-white font-semibold">الحركة</th>
                <th class="p-4 text-white font-semibold">الدقة</th>
                <th class="p-4 text-white font-semibold">التقييم</th>
              </tr>
            </thead>
            <tbody>
              {models.filter(m => m.type === 'فيديو').map((model, i) => (
                <tr class:list={['border-b border-dark-500/20 hover:bg-white/5 transition-colors', i % 2 === 0 ? 'bg-dark-700/20' : '']}>
                  <td class="p-4">
                    <a href={model.slug ? `/blog/${model.slug}` : '#'} class="text-neon-green font-medium hover:underline">{model.name}</a>
                  </td>
                  <td class="p-4 text-gray-300">{(model.name === 'Kling 3.0' || model.name === 'Sora 2 Pro' ? '⭐⭐⭐⭐⭐' : '⭐⭐⭐⭐')}</td>
                  <td class="p-4 text-gray-300">{(model.name === 'Kling 3.0' || model.name === 'Runway Gen-4.5' ? '4K' : '2K+')}</td>
                  <td class="p-4 text-neon-green font-bold">9.3+</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>