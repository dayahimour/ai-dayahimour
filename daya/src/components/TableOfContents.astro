---
interface Props {
  headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter(h => h.depth <= 3);
---

{filteredHeadings.length > 0 && (
  <nav class="glass-card p-5">
    <h4 class="text-sm font-semibold text-white mb-3 flex items-center gap-2">
      <svg class="w-4 h-4 text-neon-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
      </svg>
      محتويات المقال
    </h4>
    <ul class="space-y-1.5">
      {filteredHeadings.map(heading => (
        <li style={`padding-right: ${(heading.depth - 2) * 12}px`}>
          <a
            href={`#${heading.slug}`}
            class="block text-sm text-gray-400 hover:text-neon-blue transition-colors py-0.5 hover:pr-1 border-r-2 border-transparent hover:border-neon-blue pr-3"
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}
