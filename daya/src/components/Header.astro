---
const navLinks = [
  { href: '/', label: 'الرئيسية' },
  { href: '/blog', label: 'المقالات' },
  { href: '/models', label: 'النماذج' },
  { href: '/tools', label: 'الأدوات' },
  { href: '/future', label: 'المستقبل' },
  { href: '/about', label: 'من نحن' },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 bg-dark-900/80 backdrop-blur-xl border-b border-dark-500/20">
  <div class="max-w-7xl mx-auto px-4">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group">
        <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-neon-blue to-neon-green flex items-center justify-center group-hover:shadow-lg group-hover:shadow-neon-blue/20 transition-shadow">
          <svg class="w-5 h-5 text-dark-900" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" />
          </svg>
        </div>
        <span class="text-lg font-bold text-white">AI <span class="gradient-text">DayaHimour</span></span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              'px-4 py-2 rounded-lg text-sm font-medium transition-all duration-200',
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'text-neon-blue bg-neon-blue/10'
                : 'text-gray-400 hover:text-white hover:bg-dark-600/50'
            ]}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden w-10 h-10 rounded-lg bg-dark-700 flex items-center justify-center text-gray-400 hover:text-white transition-colors"
        aria-label="فتح القائمة"
      >
        <svg class="w-5 h-5" id="menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg class="w-5 h-5 hidden" id="close-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-dark-500/20 bg-dark-900/95 backdrop-blur-xl">
    <nav class="flex flex-col p-4 gap-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={[
            'px-4 py-3 rounded-lg text-sm font-medium transition-colors',
            currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
              ? 'text-neon-blue bg-neon-blue/10'
              : 'text-gray-400 hover:text-white hover:bg-dark-600/50'
          ]}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-16"></div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    menuIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
  });
</script>
