---
---

<section class="relative py-24 md:py-36 overflow-hidden">
  <!-- Background Effects -->
  <div class="orb orb-blue w-96 h-96 -top-48 -right-48 animate-float"></div>
  <div class="orb orb-green w-72 h-72 bottom-0 left-1/4 animate-float" style="animation-delay: -3s;"></div>
  <div class="orb orb-purple w-64 h-64 top-1/3 -left-32 animate-float" style="animation-delay: -1.5s;"></div>

  <div class="max-w-7xl mx-auto px-4 relative z-10">
    <div class="max-w-3xl">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-neon-blue/10 border border-neon-blue/20 mb-6 animate-fade-in">
        <span class="w-2 h-2 rounded-full bg-neon-green animate-pulse"></span>
        <span class="text-sm text-neon-blue font-medium">أحدث أخبار الذكاء الاصطناعي</span>
      </div>

      <!-- Title -->
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white leading-tight mb-6 animate-slide-up">
        استكشف مستقبل
        <span class="gradient-text block mt-2">الذكاء الاصطناعي</span>
      </h1>

      <!-- Subtitle -->
      <p class="text-lg md:text-xl text-gray-400 leading-relaxed mb-10 max-w-2xl animate-slide-up" style="animation-delay: 0.2s;">
        أخبار يومية، تحليلات عميقة، مقارنات النماذج، ورؤى حصرية عن مستقبل التقنية. مصدرك العربي الأول في عالم AI.
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-wrap gap-4 animate-slide-up" style="animation-delay: 0.4s;">
        <a href="/blog" class="btn-primary">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
          </svg>
          تصفح المقالات
        </a>
        <a href="/models" class="btn-secondary">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          اكتشف النماذج
        </a>
      </div>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-16 animate-slide-up" style="animation-delay: 0.6s;">
      <div class="glass-card p-4 text-center">
        <div class="text-2xl md:text-3xl font-bold gradient-text mb-1">+50</div>
        <div class="text-xs text-gray-400">مقالة ومراجعة</div>
      </div>
      <div class="glass-card p-4 text-center">
        <div class="text-2xl md:text-3xl font-bold gradient-text mb-1">+20</div>
        <div class="text-xs text-gray-400">نموذج AI محلل</div>
      </div>
      <div class="glass-card p-4 text-center">
        <div class="text-2xl md:text-3xl font-bold gradient-text mb-1">+30</div>
        <div class="text-xs text-gray-400">أداة AI مراجعة</div>
      </div>
      <div class="glass-card p-4 text-center">
        <div class="text-2xl md:text-3xl font-bold gradient-text mb-1">يومي</div>
        <div class="text-xs text-gray-400">محتوى جديد</div>
      </div>
    </div>
  </div>
</section>
